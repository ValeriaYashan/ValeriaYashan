---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf())
  .slice(0, 3);
---

<BaseLayout
  title="Valeria Yashan — Gestión de Proyectos e IA Aplicada"
  description="Valeria Yashan, PMP® certificada desde 2013. Consultora en gestión de proyectos e inteligencia artificial aplicada para equipos en Argentina y Latinoamérica."
  schema={{
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Valeria Yashan",
    "url": "https://valeriayashan.com.ar",
    "image": "https://valeriayashan.com.ar/images/valeria-yashan.webp",
    "jobTitle": "Project Manager · Consultora en IA · Autora",
    "description": "Consultora en Project Management e Inteligencia Artificial aplicada. PMP® certificada desde 2013. Autora, docente y estratega.",
    "sameAs": [
      "https://www.linkedin.com/in/valeriayashan",
      "https://www.amazon.com/-/es/Valeria-Yashan/e/B0CH6XWPVZ"
    ],
    "knowsAbout": ["Project Management", "Inteligencia Artificial", "PMBOK", "Gestión de proyectos ágiles"],
    "address": {
      "@type": "PostalAddress",
      "addressCountry": "AR"
    }
  }}
>

  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-inner">
        <p class="hero-eyebrow">Consultoría &middot; Capacitación &middot; Certificación PMP®</p>
        <h1 class="hero-headline">Gestioná proyectos complejos<br />con metodología e IA.</h1>
        <p class="hero-sub">Valeria Yashan &mdash; PMP® certificada desde 2013, autora de 4 libros y consultora en gestión de proyectos e inteligencia artificial aplicada para equipos en Argentina y Latinoamérica.</p>
        <div class="hero-actions">
          <a href="/servicios" class="btn btn-primary">Ver servicios</a>
          <a href="/blog" class="btn btn-outline">Leer artículos</a>
        </div>
      </div>
    </div>
  </section>

  <!-- RESULTADOS -->
  <section class="resultados">
    <div class="container">
      <div class="resultados-grid">
        <div class="resultado-item">
          <span class="resultado-icono">&rarr;</span>
          <p class="resultado-texto">Proyectos planificados y ejecutados con metodologías probadas</p>
        </div>
        <div class="resultado-item">
          <span class="resultado-icono">&rarr;</span>
          <p class="resultado-texto">Equipos capacitados para incorporar IA en su trabajo diario</p>
        </div>
        <div class="resultado-item">
          <span class="resultado-icono">&rarr;</span>
          <p class="resultado-texto">Profesionales acompañados en su preparación para la certificación PMP®</p>
        </div>
      </div>
    </div>
  </section>

  <!-- MÉTRICAS -->
  <section class="metricas">
    <div class="container">
      <div class="metricas-grid">
        <div class="metrica-item">
          <span class="metrica-numero">+10</span>
          <span class="metrica-label">años de experiencia</span>
        </div>
        <div class="metrica-item">
          <span class="metrica-numero">4</span>
          <span class="metrica-label">libros publicados</span>
        </div>
        <div class="metrica-item">
          <span class="metrica-numero">PMP®</span>
          <span class="metrica-label">certificada desde 2013</span>
        </div>
      </div>
    </div>
  </section>

  <!-- SOBRE MÍ -->
  <section class="about">
    <div class="container">
      <div class="about-inner">
        <img src="/images/valeria-yashan.webp" alt="Valeria Yashan, consultora PMP® en gestión de proyectos e inteligencia artificial" class="about-foto" />
        <div class="about-texto">
          <h2 class="section-title">Sobre mí</h2>
          <p>Soy Project Manager certificada (PMP®) con más de diez años de experiencia en gestión de proyectos, estrategia organizacional e implementación de herramientas digitales. Trabajo con equipos que quieren mejorar su forma de planificar, ejecutar y medir resultados.</p>
          <p>En los últimos años integré la inteligencia artificial como parte de mi práctica profesional. Escribo, enseño y consulto sobre cómo aplicar IA de forma concreta y sostenible en el trabajo de proyectos.</p>
          <a href="/sobre-mi" class="btn btn-outline" style="margin-top: 1rem;">Conocer más &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- BLOG PREVIEW -->
  <section class="blog-preview">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Últimos artículos</h2>
        <a href="/blog" class="view-all">Ver todos &rarr;</a>
      </div>
      <div class="posts-grid">
        {posts.map((post) => (
          <a href={`/blog/${post.id.replace(/\.md$/, '')}`} class="post-card">
            <div class="post-meta">
              <span class="post-category">{post.data.category}</span>
              <span class="post-date">{new Date(post.data.pubDate).toLocaleDateString('es-AR', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
            </div>
            <h3 class="post-title">{post.data.title}</h3>
            <p class="post-desc">{post.data.description}</p>
            <span class="post-link">Leer artículo &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- YOUTUBE -->
  <section class="youtube-section">
    <div class="container">
      <div class="section-header">
        <div>
          <p class="section-eyebrow">Canal de YouTube</p>
          <h2 class="section-title">Contenido en video</h2>
        </div>
      </div>
      <div class="youtube-construccion">
        <div class="youtube-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="#FF0000" aria-hidden="true"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2C0 8.1 0 12 0 12s0 3.9.6 5.8a3 3 0 0 0 2.1 2.1c1.9.6 9.3.6 9.3.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1C24 15.9 24 12 24 12s0-3.9-.5-5.8zM9.7 15.5V8.5l6.3 3.5-6.3 3.5z"/></svg>
        </div>
        <p class="youtube-construccion-titulo">Canal en construcción</p>
        <p class="youtube-construccion-desc">Próximamente: videos sobre gestión de proyectos, certificación PMP® e IA aplicada. Suscribite para ser de los primeros en verlos.</p>
        <a href="https://www.youtube.com/@valeriayashan" target="_blank" rel="noopener noreferrer" class="btn-youtube">Suscribirme al canal &rarr;</a>
      </div>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section class="newsletter-section">
    <div class="container">
      <div class="newsletter-inner">
        <p class="newsletter-eyebrow">Newsletter semanal</p>
        <h2 class="newsletter-titulo">Herramientas de PM e IA que podés aplicar esta semana</h2>
        <p class="newsletter-desc">Una vez por semana. Sin spam. Solo lo que sirve para gestionar proyectos mejor.</p>
        <div class="newsletter-form">
          <script type="text/javascript">
            window.brevoAsyncInit = function() {
              Brevo.push({
                create: {
                  type: 'iframe',
                  id: 9,
                  src: 'https://sibforms.com/serve/MUIFANlkVV--cEV3qdMzJJTcJM8LiNkYuGJ8dqJ_DXvJUGt5Wf5yT43Kj_fWHr4i2LJmZk6LlzBH_8RrRnAmxV_bP7o4IFT0TwDkRmFDh2Q9DmAl02_dKqoQD9P3Fz2Bq8Hn9IFr0j5P5TjQaGHPu3PJ9oUQ7N8Y2TxV0W3Pk9'
                }
              });
            };
          </script>
          <script async src="https://sibforms.com/forms/end-form/build/main.js"></script>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA CONTACTO -->
  <section class="cta">
    <div class="container">
      <div class="cta-inner">
        <h2 class="cta-titulo">¿Trabajamos juntos?</h2>
        <p class="cta-texto">Si querés capacitar a tu equipo, incorporar IA en tu organización o necesitás acompañamiento en gestión de proyectos, escribime.</p>
        <a href="/contacto" class="btn btn-primary">Contactar</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .hero {
    padding: var(--space-xl) 0 var(--space-lg);
  }

  .hero-inner {
    max-width: 620px;
  }

  .hero-eyebrow {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .hero-headline {
    margin-bottom: 0.75rem;
  }

  .hero-sub {
    font-size: 1.1rem;
    color: var(--color-muted);
    margin-bottom: var(--space-md);
    max-width: 520px;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .resultados {
    padding: var(--space-md) 0;
    background-color: var(--color-accent);
  }

  .resultados-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  .resultado-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .resultado-icono {
    font-size: 1.1rem;
    font-weight: 700;
    color: #FFFFFF;
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  .resultado-texto {
    font-size: 0.95rem;
    font-weight: 500;
    color: #FFFFFF;
    line-height: 1.4;
    margin: 0;
  }

  .metricas {
    padding: var(--space-md) 0;
    background-color: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .metricas-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
    text-align: center;
  }

  .metrica-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .metrica-numero {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 900;
    color: var(--color-accent);
  }

  .metrica-label {
    font-size: 0.85rem;
    color: var(--color-muted);
  }

  .about {
    padding: var(--space-lg) 0;
    background-color: var(--color-surface);
  }

  .about-inner {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: var(--space-lg);
    align-items: center;
  }

  .about-foto {
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    object-position: top;
    border-radius: var(--radius);
    display: block;
  }

  .about-texto {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .about-texto p {
    color: var(--color-muted);
    line-height: 1.7;
    margin: 0;
  }

  .section-title {
    margin-bottom: var(--space-sm);
  }

  .section-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin: 0 0 0.25rem;
  }

  .blog-preview {
    padding: var(--space-lg) 0;
    background-color: var(--color-bg);
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--space-md);
  }

  .view-all {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  .post-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-decoration: none;
    transition: border-color 0.2s;
  }

  .post-card:hover {
    border-color: var(--color-accent);
  }

  .post-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .post-category {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    background: var(--color-bg);
    padding: 2px 8px;
    border-radius: 20px;
  }

  .post-date {
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  .post-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
    margin: 0.25rem 0;
  }

  .post-desc {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.6;
    flex: 1;
    margin: 0;
  }

  .post-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
    margin-top: 0.5rem;
  }

  /* YOUTUBE */
  .youtube-section {
    padding: var(--space-lg) 0;
    background-color: var(--color-surface);
  }

  .youtube-construccion {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 3rem 2rem;
    background: var(--color-bg);
    border: 1px dashed var(--color-border);
    border-radius: 12px;
    max-width: 560px;
    margin: 0 auto;
    gap: 0.75rem;
  }

  .youtube-icon {
    margin-bottom: 0.5rem;
  }

  .youtube-construccion-titulo {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
  }

  .youtube-construccion-desc {
    font-size: 0.95rem;
    color: var(--color-muted);
    line-height: 1.6;
    max-width: 400px;
    margin: 0;
  }

  .btn-youtube {
    display: inline-block;
    background: #FF0000;
    color: #ffffff;
    font-weight: 600;
    font-size: 0.9rem;
    padding: 0.7rem 1.5rem;
    border-radius: 6px;
    text-decoration: none;
    transition: opacity 0.2s;
    margin-top: 0.5rem;
  }

  .btn-youtube:hover {
    opacity: 0.88;
  }

  /* NEWSLETTER */
  .newsletter-section {
    padding: var(--space-lg) 0;
    background-color: var(--color-accent);
  }

  .newsletter-inner {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }

  .newsletter-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.55);
    margin: 0 0 0.4rem;
  }

  .newsletter-titulo {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 0.75rem;
  }

  .newsletter-desc {
    font-size: 0.95rem;
    color: rgba(255,255,255,0.75);
    margin: 0 0 1.5rem;
    line-height: 1.6;
  }

  .newsletter-form {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .newsletter-form input[type="email"] {
    flex: 1;
    min-width: 220px;
    max-width: 320px;
    padding: 0.7rem 1rem;
    border-radius: 6px;
    border: none;
    font-size: 0.9rem;
    font-family: var(--font-body);
  }

  .newsletter-form button {
    background: #ffffff;
    color: var(--color-accent);
    font-weight: 600;
    font-size: 0.9rem;
    padding: 0.7rem 1.5rem;
    border-radius: 6px;
    border: none;
    cursor: pointer;
    transition: opacity 0.2s;
    white-space: nowrap;
  }

  .newsletter-form button:hover {
    opacity: 0.9;
  }

  .cta {
    padding: var(--space-xl) 0;
    background-color: var(--color-surface);
  }

  .cta-inner {
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .cta-titulo {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
  }

  .cta-texto {
    color: var(--color-muted);
    line-height: 1.7;
    margin: 0;
  }

  @media (max-width: 700px) {
    .about-inner {
      grid-template-columns: 1fr;
    }

    .about-foto {
      aspect-ratio: 4 / 3;
      max-height: 320px;
    }

    .resultados-grid {
      grid-template-columns: 1fr;
      gap: var(--space-sm);
    }

    .metricas-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }

    .newsletter-form {
      flex-direction: column;
      align-items: center;
    }

    .newsletter-form input[type="email"] {
      width: 100%;
      max-width: 100%;
    }
  }
</style>
