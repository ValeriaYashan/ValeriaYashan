---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf())
  .slice(0, 3);
---

<BaseLayout
  title="Valeria Yashan — Gestión de Proyectos e IA Aplicada"
  description="Valeria Yashan, PMP® certificada desde 2013. Consultora en gestión de proyectos e inteligencia artificial aplicada para equipos en Argentina y Latinoamérica."
  schema={{
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Valeria Yashan",
    "url": "https://valeriayashan.com.ar",
    "image": "https://valeriayashan.com.ar/images/valeria-yashan.webp",
    "jobTitle": "Project Manager · Consultora en IA · Autora",
    "description": "Consultora en Project Management e Inteligencia Artificial aplicada. PMP® certificada desde 2013. Autora, docente y estratega.",
    "sameAs": [
      "https://www.linkedin.com/in/valeriayashan",
      "https://www.amazon.com/-/es/Valeria-Yashan/e/B0CH6XWPVZ"
    ],
    "knowsAbout": ["Project Management", "Inteligencia Artificial", "PMBOK", "Gestión de proyectos ágiles"],
    "address": {
      "@type": "PostalAddress",
      "addressCountry": "AR"
    }
  }}
>

  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-inner">
        <div class="hero-texto">
          <p class="hero-eyebrow">Consultoría &middot; Capacitación &middot; Certificación PMP®</p>
          <h1 class="hero-headline">Tus proyectos, ejecutados con metodología real e IA integrada.</h1>
          <p class="hero-sub">PMP® desde 2013, autora de 4 libros y consultora en gestión de proyectos e IA. Trabajo con equipos en Argentina, LATAM y España que quieren gestionar mejor y usar IA de forma concreta.</p>
          <div class="hero-actions">
            <a href="/servicios" class="btn btn-primary">Ver servicios</a>
            <a href="https://calendly.com/valeriayashan/30min" target="_blank" rel="noopener noreferrer" class="btn btn-outline">Agendá una sesión gratuita de 30 min &rarr;</a>
          </div>
        </div>
        <div class="hero-foto-wrap">
          <img
            src="/images/foto-valeria-busto.webp"
            alt="Valeria Yashan, consultora PMP® en gestión de proyectos e inteligencia artificial"
            class="hero-foto"
            width="480"
            height="480"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- RESULTADOS -->
  <section class="resultados">
    <div class="container">
      <div class="resultados-grid">
        <div class="resultado-item">
          <span class="resultado-icono">&rarr;</span>
          <p class="resultado-texto">Proyectos planificados y ejecutados con metodologías probadas</p>
        </div>
        <div class="resultado-item">
          <span class="resultado-icono">&rarr;</span>
          <p class="resultado-texto">Equipos capacitados para incorporar IA en su trabajo diario</p>
        </div>
        <div class="resultado-item">
          <span class="resultado-icono">&rarr;</span>
          <p class="resultado-texto">Profesionales acompañados en su preparación para la certificación PMP®</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PARA QUIÉN ES ESTO -->
  <section class="para-quien">
    <div class="container">
      <p class="section-eyebrow">¿Es para mí?</p>
      <h2 class="section-title">Este espacio es para vos si...</h2>
      <div class="para-quien-grid">

        <div class="para-quien-card">
          <div class="para-quien-icono">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          </div>
          <h3 class="para-quien-titulo">Liderás proyectos y querés hacerlo con metodología real</h3>
          <p class="para-quien-texto">Tu equipo trabaja, pero los proyectos se demoran, las responsabilidades no están claras o las decisiones se toman sin datos. Querés cambiar eso con un sistema que funcione.</p>
        </div>

        <div class="para-quien-card">
          <div class="para-quien-icono">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
          </div>
          <h3 class="para-quien-titulo">Querés incorporar IA en tu trabajo sin perder el control</h3>
          <p class="para-quien-texto">Escuchás hablar de IA en todas partes pero no sabés cómo aplicarla de forma concreta en tu día a día como PM. Buscás resultados reales, no teoría.</p>
        </div>

        <div class="para-quien-card">
          <div class="para-quien-icono">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <h3 class="para-quien-titulo">Estás preparándote para la certificación PMP®</h3>
          <p class="para-quien-texto">Querés certificarte pero no sabés por dónde empezar, cuánto tiempo dedicar o qué material usar. Buscás acompañamiento de alguien que ya recorrió ese camino.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- MÉTRICAS -->
  <section class="metricas">
    <div class="container">
      <div class="metricas-grid">
        <div class="metrica-item">
          <span class="metrica-numero">+10</span>
          <span class="metrica-label">años de experiencia</span>
        </div>
        <div class="metrica-item">
          <span class="metrica-numero">4</span>
          <span class="metrica-label">libros publicados</span>
        </div>
        <div class="metrica-item">
          <span class="metrica-numero">PMP®</span>
          <span class="metrica-label">certificada desde 2013</span>
        </div>
      </div>
    </div>
  </section>

  <!-- SOBRE MÍ -->
  <section class="about">
    <div class="container">
      <div class="about-inner">
        <img src="/images/valeria-yashan.webp" alt="Valeria Yashan, consultora PMP® en gestión de proyectos e inteligencia artificial" class="about-foto" />
        <div class="about-texto">
          <h2 class="section-title">Sobre mí</h2>
          <p>Soy Project Manager certificada (PMP®) con más de diez años de experiencia en gestión de proyectos, estrategia organizacional e implementación de herramientas digitales. Trabajo con equipos que quieren mejorar su forma de planificar, ejecutar y medir resultados.</p>
          <p>En los últimos años integré la inteligencia artificial como parte de mi práctica profesional. Escribo, enseño y asesoro sobre cómo aplicar IA de forma concreta y sostenible en el trabajo de proyectos.</p>
          <a href="/sobre-mi" class="btn btn-outline" style="margin-top: 1rem;">Conocer más &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ¿TE SUENA FAMILIAR? -->
  <section class="problemas">
    <div class="container">
      <p class="section-eyebrow">¿Te suena familiar?</p>
      <h2 class="section-title">Cuando los proyectos crecen, la gestión no siempre los acompaña</h2>
      <p class="problemas-lead">Muchas organizaciones avanzan con iniciativas valiosas pero sin una estructura que las sostenga. Estas son las señales más frecuentes.</p>
      <div class="problemas-grid">
        <div class="problema-card">
          <span class="problema-num">01</span>
          <h3 class="problema-titulo">Los proyectos se demoran sin razón clara</h3>
          <p class="problema-texto">Hay esfuerzo, pero las fechas se corren y nadie sabe exactamente por qué.</p>
        </div>
        <div class="problema-card">
          <span class="problema-num">02</span>
          <h3 class="problema-titulo">El equipo trabaja sin metodología</h3>
          <p class="problema-texto">Cada persona gestiona a su manera. El resultado depende de quién esté a cargo ese día.</p>
        </div>
        <div class="problema-card">
          <span class="problema-num">03</span>
          <h3 class="problema-titulo">La IA no termina de implementarse</h3>
          <p class="problema-texto">Se habla de IA en todas las reuniones, pero en la operación real nada cambia.</p>
        </div>
        <div class="problema-card">
          <span class="problema-num">04</span>
          <h3 class="problema-titulo">Las decisiones se toman sin datos</h3>
          <p class="problema-texto">Falta visibilidad del estado real de los proyectos para priorizar correctamente.</p>
        </div>
        <div class="problema-card">
          <span class="problema-num">05</span>
          <h3 class="problema-titulo">La capacitación no se traduce en práctica</h3>
          <p class="problema-texto">Los equipos reciben formación, pero vuelven al trabajo y siguen haciendo lo mismo.</p>
        </div>
        <div class="problema-card">
          <span class="problema-num">06</span>
          <h3 class="problema-titulo">Todo depende de una sola persona</h3>
          <p class="problema-texto">Si quien sabe está ausente, el proyecto frena. La organización no puede escalar así.</p>
        </div>
      </div>
      <div class="problemas-cta">
        <p class="problemas-cta-texto">Si alguno de estos escenarios te resulta familiar, puedo ayudarte.</p>
        <a href="/servicios" class="btn btn-primary">Ver cómo trabajo &rarr;</a>
      </div>
    </div>
  </section>

  <!-- TESTIMONIOS -->
  <section class="testimonios">
    <div class="container">
      <p class="section-eyebrow">Testimonios</p>
      <h2 class="section-title">Lo que dicen quienes trabajaron conmigo</h2>
      <div class="testimonios-grid">

        <div class="testimonio-card">
          <p class="testimonio-texto">"Necesitábamos dejar de operar por intuición y empezar a gestionar con datos. Valeria mapeó nuestros procesos, identificó los cuellos de botella y definió los KPIs que realmente importaban para escalar. Por primera vez tenemos visibilidad real de productividad y rentabilidad en un solo lugar."</p>
          <div class="testimonio-autor">
            <div class="testimonio-avatar">M.R.</div>
            <div>
              <p class="testimonio-nombre">M.R.</p>
              <p class="testimonio-rol">Dirección · Estudio contable</p>
            </div>
          </div>
        </div>

        <div class="testimonio-card">
          <p class="testimonio-texto">"Teníamos el equipo y las ganas, pero los proyectos se nos escapaban de las manos. Valeria nos ayudó a estructurar la operación, definir responsabilidades claras y armar un tablero de seguimiento que hoy usamos en cada reunión. El cambio fue inmediato."</p>
          <div class="testimonio-autor">
            <div class="testimonio-avatar">C.P.</div>
            <div>
              <p class="testimonio-nombre">C.P.</p>
              <p class="testimonio-rol">Gerencia de Operaciones · Empresa de tecnología</p>
            </div>
          </div>
        </div>

        <div class="testimonio-card">
          <p class="testimonio-texto">"Lo que más valoré fue que no trajo una solución genérica: analizó nuestra realidad, entendió cómo trabajamos y diseñó un sistema que el equipo pudo adoptar sin fricciones. Los tiempos de entrega mejoraron y los retrabajos bajaron notablemente."</p>
          <div class="testimonio-autor">
            <div class="testimonio-avatar">L.V.</div>
            <div>
              <p class="testimonio-nombre">L.V.</p>
              <p class="testimonio-rol">Coordinación de Proyectos · Consultora regional</p>
            </div>
          </div>
        </div>

        <div class="testimonio-card">
          <p class="testimonio-texto">"Necesitábamos implementar IA en nuestra operación sin perder el control del proceso. Valeria nos guió paso a paso: desde identificar dónde tenía sentido aplicarla hasta capacitar al equipo para usarla de forma sostenible. Hoy ahorramos horas semanales en tareas que antes hacíamos a mano."</p>
          <div class="testimonio-autor">
            <div class="testimonio-avatar">F.M.</div>
            <div>
              <p class="testimonio-nombre">F.M.</p>
              <p class="testimonio-rol">Dirección General · Empresa de servicios</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- CAPACITACIONES EN VIVO -->
  <section class="capacitaciones-home">
    <div class="capacitaciones-home-inner">
      <div class="cap-header">
        <div>
          <p class="cap-eyebrow">Capacitaciones en vivo</p>
          <h2 class="cap-titulo">Aprendé gestión de proyectos e IA en vivo, por Zoom</h2>
          <p class="cap-subtitulo">
            Sesiones grupales en vivo, grupos reducidos y acompañamiento directo.
            Si ya estás inscripto/a, encontrás el acceso a tu sesión en
            <a href="/capacitaciones" class="cap-link">la página de capacitaciones</a>.
          </p>
        </div>
      </div>
      <div class="cap-grid">
        <div class="cap-card">
          <div class="cap-card-icon">🎯</div>
          <h3 class="cap-card-titulo">Preparación para el examen PMP®</h3>
          <p class="cap-card-desc">Preparate para rendir y aprobar la certificación más reconocida en gestión de proyectos. Teoría aplicada, simulacros y estrategia para el examen.</p>
          <a href="https://wa.me/541140791007?text=Hola%20Valeria%2C%20me%20interesa%20la%20capacitaci%C3%B3n%20de%20Preparaci%C3%B3n%20PMP%C2%AE" class="cap-card-cta" target="_blank" rel="noopener">Consultá por WhatsApp →</a>
        </div>
        <div class="cap-card">
          <div class="cap-card-icon">🤖</div>
          <h3 class="cap-card-titulo">IA aplicada para Project Managers</h3>
          <p class="cap-card-desc">Prompts reales, flujos de trabajo con IA y herramientas concretas para aplicar inteligencia artificial en la gestión diaria de proyectos.</p>
          <a href="https://wa.me/541140791007?text=Hola%20Valeria%2C%20me%20interesa%20la%20capacitaci%C3%B3n%20de%20IA%20para%20Project%20Managers" class="cap-card-cta" target="_blank" rel="noopener">Consultá por WhatsApp →</a>
        </div>
        <div class="cap-card">
          <div class="cap-card-icon">📋</div>
          <h3 class="cap-card-titulo">Gestión de Proyectos para equipos</h3>
          <p class="cap-card-desc">Capacitación práctica para equipos que quieren estructurar su forma de trabajar, definir responsabilidades y hacer seguimiento real de sus proyectos.</p>
          <a href="https://wa.me/541140791007?text=Hola%20Valeria%2C%20me%20interesa%20la%20capacitaci%C3%B3n%20de%20Gesti%C3%B3n%20de%20Proyectos%20para%20equipos" class="cap-card-cta" target="_blank" rel="noopener">Consultá por WhatsApp →</a>
        </div>
      </div>
      <div class="cap-footer">
        <p class="cap-footer-texto">Todas las capacitaciones se dictan en vivo por Zoom, en grupos reducidos.</p>
        <a href="/capacitaciones" class="cap-footer-btn">Ver todas las capacitaciones →</a>
      </div>
    </div>
  </section>

  <!-- BLOG PREVIEW -->
  <section class="blog-preview">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Últimos artículos</h2>
        <a href="/blog" class="view-all">Ver todos &rarr;</a>
      </div>
      <div class="posts-grid">
        {posts.map((post) => (
          <a href={`/blog/${post.id.replace(/\.md$/, '')}`} class="post-card">
            <div class="post-meta">
              <span class="post-category">{post.data.category}</span>
              <span class="post-date">{new Date(post.data.pubDate).toLocaleDateString('es-AR', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
            </div>
            <h3 class="post-title">{post.data.title}</h3>
            <p class="post-desc">{post.data.description}</p>
            <span class="post-link">Leer artículo &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- YOUTUBE -->
  <section class="youtube-section">
    <div class="container">
      <div class="section-header">
        <div>
          <p class="section-eyebrow">Canal de YouTube</p>
          <h2 class="section-title">Contenido en video</h2>
        </div>
      </div>
      <div class="youtube-construccion">
        <div class="youtube-icon-wrap">
          <svg width="32" height="23" viewBox="0 0 32 23" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M31.4 3.6A4 4 0 0 0 28.6.8C26.1 0 16 0 16 0S5.9 0 3.4.8A4 4 0 0 0 .6 3.6C0 6.1 0 11.5 0 11.5s0 5.4.6 7.9A4 4 0 0 0 3.4 22.2C5.9 23 16 23 16 23s10.1 0 12.6-.8a4 4 0 0 0 2.8-2.8C32 16.9 32 11.5 32 11.5s0-5.4-.6-7.9z" fill="white"/>
            <path d="M13 16.5l8.5-5-8.5-5v10z" fill="#FF0000"/>
          </svg>
        </div>
        <div class="youtube-tags">
          <span class="youtube-tag">Project Management</span>
          <span class="youtube-tag">Certificación PMP®</span>
          <span class="youtube-tag">IA aplicada</span>
        </div>
        <p class="youtube-construccion-desc">Videos prácticos para gestionar mejor tus proyectos e incorporar IA en tu trabajo. Suscribite para no perderte ninguno.</p>
        <a href="https://www.youtube.com/@ValeriaYashanPM" target="_blank" rel="noopener noreferrer" class="btn-youtube">Ir al canal &rarr;</a>
      </div>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section class="newsletter-section">
    <div class="container">
      <div class="newsletter-inner">
        <p class="newsletter-eyebrow">Newsletter semanal</p>
        <h2 class="newsletter-titulo">Un recurso de PM o IA aplicable esta semana — directo a tu bandeja.</h2>
        <p class="newsletter-desc">Suscribite y recibí de regalo el checklist de cierre de proyecto que uso con mis clientes.</p>
        <div class="newsletter-form">
          <div class="newsletter-iframe-wrap"><iframe title="Formulario de suscripción al newsletter" loading="lazy" height="420" src="https://a55096c1.sibforms.com/v2/serve/MUIFANq7Ejc7HcoQmak19v6LMCBF30dP4TIiNoM1t8h5eSbTtWQ4IfCj01uDg_8U55RsoMLNJS274dzOcW6sbYvfoBK6khQpZNNSUbra8acptq7niSl1gKxXuiLk8lOdtUH57JL4P-QCQjP2XiLqgZY5ki-bFDfXT9W4nYXUiJZgi30UOuLj8-5mdyiWfQA9v6o0zlm6hHMrx78WMg==" frameborder="0" scrolling="auto" allowfullscreen style="display: block; margin-left: auto; margin-right: auto; max-width: 100%;"></iframe></div>
          <div class="newsletter-substack">
            <p>¿Preferís leer en Substack?</p>
            <a href="https://substack.com/@valeriayashanpm" target="_blank" rel="noopener noreferrer" class="btn-substack">Leer en Substack →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA CONTACTO -->
  <section class="cta">
    <div class="container">
      <div class="cta-inner">
        <h2 class="cta-titulo">¿Trabajamos juntos?</h2>
        <p class="cta-texto">Si querés capacitar a tu equipo, incorporar IA en tu organización o necesitás acompañamiento en gestión de proyectos, escribime.</p>
        <a href="/contacto" class="btn btn-primary">Contactar</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .hero {
    padding: var(--space-xl) 0 var(--space-lg);
    overflow: hidden;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: var(--space-lg);
    align-items: center;
  }

  .hero-texto {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .hero-eyebrow {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .hero-headline {
    margin-bottom: 0.75rem;
  }

  .hero-sub {
    font-size: 1.05rem;
    color: var(--color-muted);
    margin-bottom: var(--space-md);
    max-width: 520px;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-foto-wrap {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0,0,0,0.10);
    aspect-ratio: 4 / 5;
    max-height: 520px;
  }

  .hero-foto {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }

  .resultados {
    padding: var(--space-md) 0;
    background-color: var(--color-accent);
  }

  .resultados-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  .resultado-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .resultado-icono {
    font-size: 1.1rem;
    font-weight: 700;
    color: #FFFFFF;
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  .resultado-texto {
    font-size: 0.95rem;
    font-weight: 500;
    color: #FFFFFF;
    line-height: 1.4;
    margin: 0;
  }

  .metricas {
    padding: var(--space-md) 0;
    background-color: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .metricas-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
    text-align: center;
  }

  .metrica-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .metrica-numero {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 900;
    color: var(--color-accent);
  }

  .metrica-label {
    font-size: 0.85rem;
    color: var(--color-muted);
  }

  .about {
    padding: var(--space-lg) 0;
    background-color: var(--color-surface);
  }

  .about-inner {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: var(--space-lg);
    align-items: center;
  }

  .about-foto {
