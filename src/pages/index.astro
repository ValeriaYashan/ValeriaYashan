---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf())
  .slice(0, 3);
---

<BaseLayout
  title="Valeria Yashan — Gestión de Proyectos e IA Aplicada"
  description="Valeria Yashan, PMP® certificada desde 2013. Consultora en gestión de proyectos e inteligencia artificial aplicada para equipos en Argentina y Latinoamérica."
  schema={{
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Valeria Yashan",
    "url": "https://valeriayashan.com.ar",
    "image": "https://valeriayashan.com.ar/images/valeria-yashan.jpg",
    "jobTitle": "Project Manager · Consultora en IA · Autora",
    "description": "Consultora en Project Management e Inteligencia Artificial aplicada. PMP® certificada desde 2013. Autora, docente y estratega.",
    "sameAs": [
      "https://www.linkedin.com/in/valeriayashan",
      "https://www.amazon.com/-/es/Valeria-Yashan/e/B0CH6XWPVZ"
    ],
    "knowsAbout": ["Project Management", "Inteligencia Artificial", "PMBOK", "Gestión de proyectos ágiles"],
    "address": {
      "@type": "PostalAddress",
      "addressCountry": "AR"
    }
  }}
>
  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-inner">
        <p class="hero-eyebrow">Consultor&iacute;a &middot; Capacitaci&oacute;n &middot; Certificaci&oacute;n PMP&reg;</p>
        <h1 class="hero-headline">Gestion&aacute; proyectos complejos<br />con metodolog&iacute;a e IA.</h1>
        <p class="hero-sub">Valeria Yashan &mdash; PMP&reg; certificada desde 2013, autora de 4 libros y consultora en gesti&oacute;n de proyectos e inteligencia artificial aplicada para equipos en Argentina y Latinoam&eacute;rica.</p>
        <div class="hero-actions">
          <a href="/servicios" class="btn btn-primary">Ver servicios</a>
          <a href="/blog" class="btn btn-outline">Leer art&iacute;culos</a>
        </div>
      </div>
    </div>
  </section>

  <!-- RESULTADOS -->
  <section class="resultados">
    <div class="container">
      <div class="resultados-grid">
        <div class="resultado-item">
          <span class="resultado-icono">&rarr;</span>
          <p class="resultado-texto">Proyectos planificados y ejecutados con metodolog&iacute;as probadas</p>
        </div>
        <div class="resultado-item">
          <span class="resultado-icono">&rarr;</span>
          <p class="resultado-texto">Equipos capacitados para incorporar IA en su trabajo diario</p>
        </div>
        <div class="resultado-item">
          <span class="resultado-icono">&rarr;</span>
          <p class="resultado-texto">Profesionales acompa&ntilde;ados en su preparaci&oacute;n para la certificaci&oacute;n PMP&reg;</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SOBRE MÍ -->
  <section class="about">
    <div class="container">
      <div class="about-inner">
        <img src="/images/valeria-yashan.jpg" alt="Valeria Yashan — Project Manager y autora" class="about-foto" />
        <div class="about-texto">
          <h2 class="section-title">Sobre m&iacute;</h2>
          <p>Soy Project Manager certificada (PMP&reg;) con m&aacute;s de diez a&ntilde;os de experiencia en gesti&oacute;n de proyectos, estrategia organizacional e implementaci&oacute;n de herramientas digitales. Trabajo con equipos que quieren mejorar su forma de planificar, ejecutar y medir resultados.</p>
          <p>En los &uacute;ltimos a&ntilde;os integr&eacute; la inteligencia artificial como parte de mi pr&aacute;ctica profesional. Escribo, ense&ntilde;o y consulto sobre c&oacute;mo aplicar IA de forma concreta y sostenible en el trabajo de proyectos.</p>
          <a href="/sobre-mi" class="btn btn-outline" style="margin-top: 1rem;">Conocer m&aacute;s &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- BLOG PREVIEW -->
  <section class="blog-preview">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">&Uacute;ltimos art&iacute;culos</h2>
        <a href="/blog" class="view-all">Ver todos &rarr;</a>
      </div>
      <div class="posts-grid">
        {posts.map((post) => (
          <a href={`/blog/${post.id.replace(/\.md$/, '')}`} class="post-card">
            <div class="post-meta">
              <span class="post-category">{post.data.category}</span>
              <span class="post-date">{new Date(post.data.pubDate).toLocaleDateString('es-AR', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
            </div>
            <h3 class="post-title">{post.data.title}</h3>
            <p class="post-desc">{post.data.description}</p>
            <span class="post-link">Leer art&iacute;culo &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA CONTACTO -->
  <section class="cta">
    <div class="container">
      <div class="cta-inner">
        <h2 class="cta-titulo">&iquest;Trabajamos juntos?</h2>
        <p class="cta-texto">Si quer&eacute;s capacitar a tu equipo, incorporar IA en tu organizaci&oacute;n o necesit&aacute;s acompa&ntilde;amiento en gesti&oacute;n de proyectos, escribime.</p>
        <a href="/contacto" class="btn btn-primary">Contactar</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* HERO */
  .hero {
    padding: var(--space-xl) 0 var(--space-lg);
  }

  .hero-inner {
    max-width: 620px;
  }

  .hero-eyebrow {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .hero-headline {
    margin-bottom: 0.75rem;
  }

  .hero-sub {
    font-size: 1.1rem;
    color: var(--color-muted);
    margin-bottom: var(--space-md);
    max-width: 520px;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* RESULTADOS */
  .resultados {
    padding: var(--space-md) 0;
    background-color: var(--color-accent);
  }

  .resultados-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  .resultado-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .resultado-icono {
    font-size: 1.1rem;
    font-weight: 700;
    color: #FFFFFF;
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  .resultado-texto {
    font-size: 0.95rem;
    font-weight: 500;
    color: #FFFFFF;
    line-height: 1.4;
    margin: 0;
  }

  /* SOBRE MÍ */
  .about {
    padding: var(--space-lg) 0;
    background-color: var(--color-surface);
  }

  .about-inner {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: var(--space-lg);
    align-items: center;
  }

  .about-foto {
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    object-position: top;
    border-radius: var(--radius);
    display: block;
  }

  .about-texto {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .about-texto p {
    color: var(--color-muted);
    line-height: 1.7;
    margin: 0;
  }

  .section-title {
    margin-bottom: var(--space-sm);
  }

  /* BLOG PREVIEW */
  .blog-preview {
    padding: var(--space-lg) 0;
    background-color: var(--color-bg);
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--space-md);
  }

  .view-all {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  .post-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-decoration: none;
    transition: border-color 0.2s;
  }

  .post-card:hover {
    border-color: var(--color-accent);
  }

  .post-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .post-category {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    background: var(--color-bg);
    padding: 2px 8px;
    border-radius: 20px;
  }

  .post-date {
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  .post-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
    margin: 0.25rem 0;
  }

  .post-desc {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.6;
    flex: 1;
    margin: 0;
  }

  .post-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
    margin-top: 0.5rem;
  }

  /* CTA */
  .cta {
    padding: var(--space-xl) 0;
    background-color: var(--color-surface);
  }

  .cta-inner {
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .cta-titulo {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
  }

  .cta-texto {
    color: var(--color-muted);
    line-height: 1.7;
    margin: 0;
  }

  /* RESPONSIVE */
  @media (max-width: 700px) {
    .about-inner {
      grid-template-columns: 1fr;
    }

    .about-foto {
      aspect-ratio: 4 / 3;
      max-height: 320px;
    }

    .resultados-grid {
      grid-template-columns: 1fr;
      gap: var(--space-sm);
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>