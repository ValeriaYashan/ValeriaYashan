---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf());
---

<BaseLayout
  title="Artículos — Valeria Yashan"
  description="Artículos sobre gestión de proyectos, inteligencia artificial aplicada, productividad y herramientas digitales."
>

  <section class="blog-hero">
    <div class="container">
      <p class="eyebrow">Blog</p>
      <h1>Artículos</h1>
      <p class="bajada">Escribo sobre gestión de proyectos, inteligencia artificial aplicada, productividad y herramientas digitales. Sin relleno, con ejemplos concretos.</p>
    </div>
  </section>

  <section class="blog-lista">
    <div class="container">
      {posts.map((post) => (
        <article class="post-item">
          <div class="post-meta">
            <span class="post-category">{post.data.category}</span>
            <span class="post-date">{new Date(post.data.pubDate).toLocaleDateString('es-AR', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
          </div>
          <h2 class="post-titulo">
            <a href={`/blog/${post.id.replace(/\.md$/, '')}`}>{post.data.title}</a>
          </h2>
          <p class="post-desc">{post.data.description}</p>
          <a href={`/blog/${post.id.replace(/\.md$/, '')}`} class="post-link">Leer artículo →</a>
        </article>
      ))}
    </div>

    <div class="container newsletter-bloque">
      <div class="newsletter-card">
        <p class="newsletter-eyebrow">Newsletter</p>
        <h2 class="newsletter-titulo">Recibí los próximos artículos</h2>
        <p class="newsletter-desc">Sin spam. Solo cuando publico algo que vale la pena leer.</p>
        <a href="/recursos" class="btn btn-primary">Suscribirme →</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .blog-hero {
    padding: var(--space-xl) 0 var(--space-md);
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  .bajada {
    font-size: 1.05rem;
    color: var(--color-muted);
    max-width: 600px;
    line-height: 1.7;
    margin-top: 0.5rem;
  }

  .blog-lista {
    padding-bottom: var(--space-xl);
  }

  .post-item {
    border-top: 1px solid var(--color-border);
    padding: var(--space-md) 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .post-category {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    background: var(--color-surface);
    padding: 2px 8px;
    border-radius: 20px;
  }

  .post-date {
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  .post-titulo {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 600;
    line-height: 1.25;
    margin: 0;
  }

  .post-titulo a {
    color: var(--color-text);
    text-decoration: none;
  }

  .post-titulo a:hover {
    color: var(--color-accent);
  }

  .post-desc {
    font-size: 0.95rem;
    color: var(--color-muted);
    line-height: 1.6;
    max-width: 650px;
    margin: 0;
  }

  .post-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    align-self: flex-start;
  }

  .newsletter-bloque {
    margin-top: var(--space-lg);
  }

  .newsletter-card {
    border-left: 3px solid var(--color-accent);
    padding: var(--space-md);
    background: var(--color-surface);
    border-radius: var(--radius);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    max-width: 520px;
  }

  .newsletter-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin: 0;
  }

  .newsletter-titulo {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 600;
    margin: 0;
  }

  .newsletter-desc {
    font-size: 0.9rem;
    color: var(--color-muted);
    margin: 0;
  }

  @media (max-width: 600px) {
    .post-titulo {
      font-size: 1.1rem;
    }
  }
</style>
