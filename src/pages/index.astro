---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf())
  .slice(0, 3);
---

<BaseLayout
  title="Valeria Yashan — Gestión de Proyectos e IA Aplicada"
  description="Valeria Yashan, PMP® certificada desde 2013. Consultora en gestión de proyectos e inteligencia artificial aplicada para equipos en Argentina y Latinoamérica."
  schema={{
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Valeria Yashan",
    "url": "https://valeriayashan.com.ar",
    "image": "https://valeriayashan.com.ar/images/valeria-yashan.webp",
    "jobTitle": "Project Manager · Consultora en IA · Autora",
    "description": "Consultora en Project Management e Inteligencia Artificial aplicada. PMP® certificada desde 2013. Autora, docente y estratega.",
    "sameAs": [
      "https://www.linkedin.com/in/valeriayashan",
      "https://www.amazon.com/-/es/Valeria-Yashan/e/B0CH6XWPVZ"
    ],
    "knowsAbout": ["Project Management", "Inteligencia Artificial", "PMBOK", "Gestión de proyectos ágiles"],
    "address": {
      "@type": "PostalAddress",
      "addressCountry": "AR"
    }
  }}
>

  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-inner">
        <p class="hero-eyebrow">Consultoría &middot; Capacitación &middot; Certificación PMP®</p>
        <h1 class="hero-headline">Tus proyectos, ejecutados con<br />metodología real e IA integrada.</h1>
        <p class="hero-sub">Valeria Yashan &mdash; PMP® desde 2013, autora de 4 libros y consultora en gestión de proyectos e IA. Trabajo con equipos en Argentina, LATAM y España que quieren gestionar mejor y usar IA de forma concreta.</p>
        <div class="hero-actions">
          <a href="/servicios" class="btn btn-primary">Ver servicios</a>
          <a href="/blog" class="btn btn-outline">Leer artículos</a>
        </div>
      </div>
    </div>
  </section>

  <!-- RESULTADOS -->
  <section class="resultados">
    <div class="container">
      <div class="resultados-grid">
        <div class="resultado-item">
          <span class="resultado-icono">&rarr;</span>
          <p class="resultado-texto">Proyectos planificados y ejecutados con metodologías probadas</p>
        </div>
        <div class="resultado-item">
          <span class="resultado-icono">&rarr;</span>
          <p class="resultado-texto">Equipos capacitados para incorporar IA en su trabajo diario</p>
        </div>
        <div class="resultado-item">
          <span class="resultado-icono">&rarr;</span>
          <p class="resultado-texto">Profesionales acompañados en su preparación para la certificación PMP®</p>
        </div>
      </div>
    </div>
  </section>

  <!-- MÉTRICAS -->
  <section class="metricas">
    <div class="container">
      <div class="metricas-grid">
        <div class="metrica-item">
          <span class="metrica-numero">+10</span>
          <span class="metrica-label">años de experiencia</span>
        </div>
        <div class="metrica-item">
          <span class="metrica-numero">4</span>
          <span class="metrica-label">libros publicados</span>
        </div>
        <div class="metrica-item">
          <span class="metrica-numero">PMP®</span>
          <span class="metrica-label">certificada desde 2013</span>
        </div>
      </div>
    </div>
  </section>

  <!-- SOBRE MÍ -->
  <section class="about">
    <div class="container">
      <div class="about-inner">
        <img src="/images/valeria-yashan.webp" alt="Valeria Yashan, consultora PMP® en gestión de proyectos e inteligencia artificial" class="about-foto" />
        <div class="about-texto">
          <h2 class="section-title">Sobre mí</h2>
          <p>Soy Project Manager certificada (PMP®) con más de diez años de experiencia en gestión de proyectos, estrategia organizacional e implementación de herramientas digitales. Trabajo con equipos que quieren mejorar su forma de planificar, ejecutar y medir resultados.</p>
          <p>En los últimos años integré la inteligencia artificial como parte de mi práctica profesional. Escribo, enseño y asesoro sobre cómo aplicar IA de forma concreta y sostenible en el trabajo de proyectos.</p>
          <a href="/sobre-mi" class="btn btn-outline" style="margin-top: 1rem;">Conocer más &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ¿TE SUENA FAMILIAR? -->
  <section class="problemas">
    <div class="container">
      <p class="section-eyebrow">¿Te suena familiar?</p>
      <h2 class="section-title">Cuando los proyectos crecen, la gestión no siempre los acompaña</h2>
      <p class="problemas-lead">Muchas organizaciones avanzan con iniciativas valiosas pero sin una estructura que las sostenga. Estas son las señales más frecuentes.</p>
      <div class="problemas-grid">
        <div class="problema-card">
          <span class="problema-num">01</span>
          <h3 class="problema-titulo">Los proyectos se demoran sin razón clara</h3>
          <p class="problema-texto">Hay esfuerzo, pero las fechas se corren y nadie sabe exactamente por qué.</p>
        </div>
        <div class="problema-card">
          <span class="problema-num">02</span>
          <h3 class="problema-titulo">El equipo trabaja sin metodología</h3>
          <p class="problema-texto">Cada persona gestiona a su manera. El resultado depende de quién esté a cargo ese día.</p>
        </div>
        <div class="problema-card">
          <span class="problema-num">03</span>
          <h3 class="problema-titulo">La IA no termina de implementarse</h3>
          <p class="problema-texto">Se habla de IA en todas las reuniones, pero en la operación real nada cambia.</p>
        </div>
        <div class="problema-card">
          <span class="problema-num">04</span>
          <h3 class="problema-titulo">Las decisiones se toman sin datos</h3>
          <p class="problema-texto">Falta visibilidad del estado real de los proyectos para priorizar correctamente.</p>
        </div>
        <div class="problema-card">
          <span class="problema-num">05</span>
          <h3 class="problema-titulo">La capacitación no se traduce en práctica</h3>
          <p class="problema-texto">Los equipos reciben formación, pero vuelven al trabajo y siguen haciendo lo mismo.</p>
        </div>
        <div class="problema-card">
          <span class="problema-num">06</span>
          <h3 class="problema-titulo">Todo depende de una sola persona</h3>
          <p class="problema-texto">Si quien sabe está ausente, el proyecto frena. La organización no puede escalar así.</p>
        </div>
      </div>
      <div class="problemas-cta">
        <p class="problemas-cta-texto">Si alguno de estos escenarios te resulta familiar, puedo ayudarte.</p>
        <a href="/servicios" class="btn btn-primary">Ver cómo trabajo &rarr;</a>
      </div>
    </div>
  </section>

  <!-- TESTIMONIOS -->
  <section class="testimonios" style="display:none">
    <div class="container">
      <p class="section-eyebrow">Testimonios</p>
      <h2 class="section-title">Lo que dicen quienes trabajaron conmigo</h2>
      <div class="testimonios-grid">

        <div class="testimonio-card">
          <p class="testimonio-texto">"Texto del testimonio. Resultado concreto que obtuvo esta persona trabajando con Valeria."</p>
          <div class="testimonio-autor">
            <div class="testimonio-avatar">N</div>
            <div>
              <p class="testimonio-nombre">Nombre Apellido</p>
              <p class="testimonio-rol">Rol · Empresa</p>
            </div>
          </div>
        </div>

        <div class="testimonio-card">
          <p class="testimonio-texto">"Texto del testimonio. Resultado concreto que obtuvo esta persona trabajando con Valeria."</p>
          <div class="testimonio-autor">
            <div class="testimonio-avatar">N</div>
            <div>
              <p class="testimonio-nombre">Nombre Apellido</p>
              <p class="testimonio-rol">Rol · Empresa</p>
            </div>
          </div>
        </div>

        <div class="testimonio-card">
          <p class="testimonio-texto">"Texto del testimonio. Resultado concreto que obtuvo esta persona trabajando con Valeria."</p>
          <div class="testimonio-autor">
            <div class="testimonio-avatar">N</div>
            <div>
              <p class="testimonio-nombre">Nombre Apellido</p>
              <p class="testimonio-rol">Rol · Empresa</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- BLOG PREVIEW -->
  <section class="blog-preview">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Últimos artículos</h2>
        <a href="/blog" class="view-all">Ver todos &rarr;</a>
      </div>
      <div class="posts-grid">
        {posts.map((post) => (
          <a href={`/blog/${post.id.replace(/\.md$/, '')}`} class="post-card">
            <div class="post-meta">
              <span class="post-category">{post.data.category}</span>
              <span class="post-date">{new Date(post.data.pubDate).toLocaleDateString('es-AR', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
            </div>
            <h3 class="post-title">{post.data.title}</h3>
            <p class="post-desc">{post.data.description}</p>
            <span class="post-link">Leer artículo &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- YOUTUBE -->
  <section class="youtube-section">
    <div class="container">
      <div class="section-header">
        <div>
          <p class="section-eyebrow">Canal de YouTube</p>
          <h2 class="section-title">Contenido en video</h2>
        </div>
      </div>
      <div class="youtube-construccion">
        <div class="youtube-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="#FF0000" aria-hidden="true"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2C0 8.1 0 12 0 12s0 3.9.6 5.8a3 3 0 0 0 2.1 2.1c1.9.6 9.3.6 9.3.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1C24 15.9 24 12 24 12s0-3.9-.5-5.8zM9.7 15.5V8.5l6.3 3.5-6.3 3.5z"/></svg>
        </div>
        <p class="youtube-construccion-titulo">Canal en construcción</p>
        <p class="youtube-construccion-desc">Próximamente: videos sobre gestión de proyectos, certificación PMP® e IA aplicada. Próximamente: videos sobre gestión de proyectos, certificación PMP® e IA aplicada..</p>
        <a href="https://www.youtube.com/@valeriayashan" target="_blank" rel="noopener noreferrer" class="btn-youtube">Seguir el canal &rarr;;</a>
      </div>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section class="newsletter-section">
    <div class="container">
      <div class="newsletter-inner">
        <p class="newsletter-eyebrow">Newsletter semanal</p>
        <h2 class="newsletter-titulo">Un recurso de PM o IA aplicable esta semana — directo a tu bandeja.</h2>
        <p class="newsletter-desc">Suscribite y recibí de regalo el checklist de cierre de proyecto que uso con mis clientes.</p>
        <div class="newsletter-form">
          <iframe width="540" height="420" src="https://a55096c1.sibforms.com/v2/serve/MUIFANq7Ejc7HcoQmak19v6LMCBF30dP4TIiNoM1t8h5eSbTtWQ4IfCj01uDg_8U55RsoMLNJS274dzOcW6sbYvfoBK6khQpZNNSUbra8acptq7niSl1gKxXuiLk8lOdtUH57JL4P-QCQjP2XiLqgZY5ki-bFDfXT9W4nYXUiJZgi30UOuLj8-5mdyiWfQA9v6o0zlm6hHMrx78WMg==" frameborder="0" scrolling="auto" allowfullscreen style="display: block; margin-left: auto; margin-right: auto; max-width: 100%;"></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA CONTACTO -->
  <section class="cta">
    <div class="container">
      <div class="cta-inner">
        <h2 class="cta-titulo">¿Trabajamos juntos?</h2>
        <p class="cta-texto">Si querés capacitar a tu equipo, incorporar IA en tu organización o necesitás acompañamiento en gestión de proyectos, escribime.</p>
        <a href="/contacto" class="btn btn-primary">Contactar</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .hero {
    padding: var(--space-xl) 0 var(--space-lg);
  }

  .hero-inner {
    max-width: 620px;
  }

  .hero-eyebrow {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .hero-headline {
    margin-bottom: 0.75rem;
  }

  .hero-sub {
    font-size: 1.1rem;
    color: var(--color-muted);
    margin-bottom: var(--space-md);
    max-width: 520px;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .resultados {
    padding: var(--space-md) 0;
    background-color: var(--color-accent);
  }

  .resultados-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  .resultado-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .resultado-icono {
    font-size: 1.1rem;
    font-weight: 700;
    color: #FFFFFF;
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  .resultado-texto {
    font-size: 0.95rem;
    font-weight: 500;
    color: #FFFFFF;
    line-height: 1.4;
    margin: 0;
  }

  .metricas {
    padding: var(--space-md) 0;
    background-color: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .metricas-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
    text-align: center;
  }

  .metrica-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .metrica-numero {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 900;
    color: var(--color-accent);
  }

  .metrica-label {
    font-size: 0.85rem;
    color: var(--color-muted);
  }

  .about {
    padding: var(--space-lg) 0;
    background-color: var(--color-surface);
  }

  .about-inner {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: var(--space-lg);
    align-items: center;
  }

  .about-foto {
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    object-position: top;
    border-radius: var(--radius);
    display: block;
  }

  .about-texto {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .about-texto p {
    color: var(--color-muted);
    line-height: 1.7;
    margin: 0;
  }

  .section-title {
    margin-bottom: var(--space-sm);
  }

  .section-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin: 0 0 0.25rem;
  }

  /* PROBLEMAS */
  .problemas {
    padding: var(--space-lg) 0;
    background-color: var(--color-bg);
  }

  .problemas-lead {
    font-size: 1rem;
    color: var(--color-muted);
    max-width: 560px;
    line-height: 1.7;
    margin-bottom: var(--space-md);
  }

 .problemas-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: var(--space-md);
  }

  @media (max-width: 900px) and (min-width: 701px) {
    .problemas-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .problema-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.25rem 1rem;
  }

  .problema-num {
    display: block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: 0.6rem;
  }

  .problema-titulo {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.4rem;
    line-height: 1.35;
  }

  .problema-texto {
    font-size: 0.82rem;
    color: var(--color-muted);
    line-height: 1.65;
    margin: 0;
  }

  .problemas-cta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding-top: var(--space-sm);
    flex-wrap: wrap;
  }

  .problemas-cta-texto {
    font-size: 0.95rem;
    color: var(--color-muted);
    margin: 0;
  }

  /* TESTIMONIOS */
  .testimonios {
    padding: var(--space-lg) 0;
    background-color: var(--color-bg);
  }

  .testimonios-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
    margin-top: var(--space-md);
  }

  .testimonio-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .testimonio-texto {
    font-size: 0.95rem;
    color: var(--color-text);
    line-height: 1.7;
    font-style: italic;
    margin: 0;
    flex: 1;
  }

  .testimonio-autor {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .testimonio-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--color-accent);
    color: white;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .testimonio-nombre {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0;
  }

  .testimonio-rol {
    font-size: 0.8rem;
    color: var(--color-muted);
    margin: 0;
  }

  .blog-preview {
    padding: var(--space-lg) 0;
    background-color: var(--color-surface);
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--space-md);
  }

  .view-all {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  .post-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-decoration: none;
    transition: border-color 0.2s;
  }

  .post-card:hover {
    border-color: var(--color-accent);
  }

  .post-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .post-category {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    background: var(--color-surface);
    padding: 2px 8px;
    border-radius: 20px;
  }

  .post-date {
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  .post-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
    margin: 0.25rem 0;
  }

  .post-desc {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.6;
    flex: 1;
    margin: 0;
  }

  .post-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
    margin-top: 0.5rem;
  }

  .youtube-section {
    padding: var(--space-lg) 0;
    background-color: var(--color-bg);
  }

  .youtube-construccion {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 3rem 2rem;
    background: var(--color-surface);
    border: 1px dashed var(--color-border);
    border-radius: 12px;
    max-width: 560px;
    margin: 0 auto;
    gap: 0.75rem;
  }

  .youtube-icon {
    margin-bottom: 0.5rem;
  }

  .youtube-construccion-titulo {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
  }

  .youtube-construccion-desc {
    font-size: 0.95rem;
    color: var(--color-muted);
    line-height: 1.6;
    max-width: 400px;
    margin: 0;
  }

  .btn-youtube {
    display: inline-block;
    background: #FF0000;
    color: #ffffff;
    font-weight: 600;
    font-size: 0.9rem;
    padding: 0.7rem 1.5rem;
    border-radius: 6px;
    text-decoration: none;
    transition: opacity 0.2s;
    margin-top: 0.5rem;
  }

  .btn-youtube:hover {
    opacity: 0.88;
  }

  .newsletter-section {
    padding: var(--space-lg) 0;
    background-color: var(--color-accent);
  }

  .newsletter-inner {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }

  .newsletter-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.55);
    margin: 0 0 0.4rem;
  }

  .newsletter-titulo {
    font-family: var(--font-display);
