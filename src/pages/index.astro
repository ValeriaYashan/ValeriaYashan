---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf())
  .slice(0, 3);
---

<BaseLayout
  title="Valeria Yashan — Project Management e IA"
  description="Valeria Yashan — Consultora en Project Management e Inteligencia Artificial aplicada. Autora, docente y estratega."
>
  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-inner mark-accent">
        <p class="hero-eyebrow">Project Management · IA · Estrategia</p>
        <h1 class="hero-headline">Gestión de proyectos<br />en la era de la IA.</h1>
        <p class="hero-credenciales">PMP® · +10 años en gestión de proyectos · Autora · Docente</p>
        <p class="hero-sub">Ayudo a profesionales y organizaciones a integrar metodologías de gestión de proyectos con herramientas de inteligencia artificial. Autora, consultora y docente.</p>
        <div class="hero-actions">
          <a href="/libro" class="btn btn-primary">Ver libros</a>
          <a href="/blog" class="btn btn-outline">Leer artículos</a>
        </div>
      </div>
    </div>
  </section>

  <!-- RESULTADOS -->
  <section class="resultados">
    <div class="container">
      <div class="resultados-grid">
        <div class="resultado-item">
          <span class="resultado-icono">→</span>
          <p class="resultado-texto">Proyectos planificados y ejecutados con metodologías probadas</p>
        </div>
        <div class="resultado-item">
          <span class="resultado-icono">→</span>
          <p class="resultado-texto">Equipos capacitados para incorporar IA en su trabajo diario</p>
        </div>
        <div class="resultado-item">
          <span class="resultado-icono">→</span>
          <p class="resultado-texto">Profesionales acompañados en su preparación para la certificación PMP®</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ACERCA -->
  <section class="about">
    <div class="container">
      <div class="about-inner">
        <img src="/images/valeria-yashan.jpg" alt="Valeria Yashan — Project Manager y autora" class="about-foto" />
        <div class="about-texto">
          <h2 class="section-title">Sobre mí</h2>
          <p>Soy Project Manager certificada (PMP®) con más de diez años de experiencia en gestión de proyectos, estrategia organizacional e implementación de herramientas digitales. Trabajo con equipos que quieren mejorar su forma de planificar, ejecutar y medir resultados.</p>
          <p>En los últimos años integré la inteligencia artificial como parte de mi práctica profesional. Escribo, enseño y consulto sobre cómo aplicar IA de forma concreta y sostenible en el trabajo de proyectos.</p>
          <a href="/sobre-mi" class="btn btn-outline" style="margin-top: 1rem;">Conocer más →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- LIBROS -->
  <section class="libros">
    <div class="container">
      <p class="section-eyebrow">Libros</p>
      <h2 class="section-title">Publicaciones</h2>
      <div class="libros-grid">

        <div class="libro-card mark-accent">
          <p class="libro-label">Gestión de proyectos · Maternidad</p>
          <h3 class="libro-titulo">PM MOM</h3>
          <p class="libro-desc">El primer libro que aplica las herramientas reales de la gestión de proyectos a los primeros cinco años de la maternidad. Con templates listos para usar y un glosario de 22 términos de PM aplicados a la maternidad real.</p>
          <div class="libro-actions">
            <a href="https://www.amazon.com/gp/product/B0H34V2L3S" target="_blank" rel="noopener noreferrer" class="btn btn-amazon">Comprar en Amazon →</a>
          </div>
        </div>

        <div class="libro-card mark-accent">
          <p class="libro-label">Project Management · Certificación PMP®</p>
          <h3 class="libro-titulo">Dirección de Proyectos — Tomo III: Simulacros de Práctica Intensiva</h3>
          <p class="libro-desc">La etapa final de preparación para el examen PMP®. 180 preguntas de simulacro con distribución ECO real, respuestas con justificación detallada y diagnóstico de brechas. Alineado con PMBOK® Guide — Eighth Edition · ECO vigente desde julio 2026.</p>
          <div class="libro-actions">
            <a href="https://www.amazon.com/dp/B0H58TX7Z4?spcref=PRINT_LISTING" target="_blank" rel="noopener noreferrer" class="btn btn-amazon">Comprar en Amazon →</a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- BLOG PREVIEW -->
  <section class="blog-preview">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Últimos artículos</h2>
        <a href="/blog" class="view-all">Ver todos →</a>
      </div>
      <div class="posts-grid">
        {posts.map((post) => (
          <a href={`/blog/${post.id.replace(/\.md$/, '')}`} class="post-card">
            <div class="post-meta">
              <span class="post-category">{post.data.category}</span>
              <span class="post-date">{new Date(post.data.pubDate).toLocaleDateString('es-AR', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
            </div>
            <h3 class="post-title">{post.data.title}</h3>
            <p class="post-desc">{post.data.description}</p>
            <span class="post-link">Leer artículo →</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: var(--space-xl) 0 var(--space-lg);
  }

  .hero-inner {
    max-width: 620px;
  }

  .hero-eyebrow {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .hero-headline {
    margin-bottom: 0.5rem;
  }

  .hero-credenciales {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .hero-sub {
    font-size: 1.1rem;
    color: var(--color-muted);
    margin-bottom: var(--space-md);
    max-width: 520px;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* Resultados */
  .resultados {
    padding: var(--space-md) 0;
    background-color: var(--color-accent);
  }

  .resultados-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--space-md);
  }

  .resultado-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .resultado-icono {
    font-size: 1.1rem;
    font-weight: 700;
    color: #FFFFFF;
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  .resultado-texto {
    font-size: 0.95rem;
    font-weight: 500;
    color: #FFFFFF;
    line-height: 1.4;
    margin: 0;
  }

  /* About */
  .about {
    padding: var(--space-lg) 0;
    background-color: var(--color-surface);
  }

  .about-inner {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: var(--space-lg);
    align-items: center;
  }

  .about-foto {
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    object-position: top;
    border-radius: var(--radius);
    display: block;
  }

  .about-texto {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .about-texto p {
    color: var(--color-muted);
    line-height: 1.7;
    margin: 0;
  }

  .section-title {
    margin-bottom: var(--space-sm);
  }

  .section-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: 0.25rem;
  }

  /* Libros */
  .libros {
    padding: var(--space-lg) 0;
    background-color: var(--color-bg);
  }

  .libros-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-md);
    margin-top: var(--space-md);
  }

  .libro-card {
    background: var(--color-surface);
    padding: var(--space-md);
    border-radius: var(--radius);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .libro-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: 0.25rem;
  }

  .libro-titulo {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 400;
    line-height: 1.2;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .libro-desc {
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.6;
    flex: 1;
  }

  .libro-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 0.75rem;
  }

  .btn-amazon {
    background-color: #FF9900;
    color: #111 !important;
    border: 2px solid #FF9900;
    text-decoration: none;
  }

  .btn-amazon:hover {
    background-color: #e88a00;
    border-color: #e88a00;
    opacity: 1;
  }

  /* Blog preview */
  .blog-preview {
    padding: var(--space-lg) 0 var(--space-xl);
    background-color: var(--color-surface);
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--space-md);
  }

  .view-all {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-md);
  }

  .post-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-decoration: none;
    transition: border-color 0.2s;
  }

  .post-card:hover {
    border-color: var(--color-accent);
  }

  .post-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .post-category {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    background: var(--color-surface);
    padding: 2px 8px;
    border-radius: 20px;
  }

  .post-date {
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  .post-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
    margin: 0.25rem 0;
  }

  .post-desc {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.6;
    flex: 1;
    margin: 0;
  }

  .post-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
    margin-top: 0.5rem;
  }

  /* Responsive */
  @media (max-width: 700px) {
    .about-inner {
      grid-template-columns: 1fr;
    }

    .about-foto {
      aspect-ratio: 4 / 3;
      max-height: 320px;
    }

    .resultados-grid {
      grid-template-columns: 1fr;
      gap: var(--space-sm);
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>