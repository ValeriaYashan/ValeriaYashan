---
// src/pages/capacitaciones.astro
// Página de capacitaciones en vivo por Zoom — Valeria Yashan
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Capacitaciones en vivo por Zoom — Valeria Yashan"
  description="Capacitaciones en vivo por Zoom en gestión de proyectos, preparación PMP® e IA aplicada. Grupos reducidos, acompañamiento directo. Argentina, LATAM y España."
>

  <!-- HERO -->
  <section class="cap-hero">
    <div class="cap-hero-inner">
      <p class="cap-eyebrow">Capacitaciones en vivo</p>
      <h1 class="cap-hero-titulo">Capacitaciones por Zoom</h1>
      <p class="cap-hero-sub">
        Capacitación en vivo con grupos reducidos, metodología práctica y acompañamiento personalizado durante todo el proceso.
        Si ya estás inscripto/a, encontrás el acceso a tu sesión más abajo.
        Si querés sumarte, consultá por WhatsApp.
      </p>
      <div class="cap-hero-btns">
        <a
          href="https://wa.me/541140791007?text=Hola%20Valeria%2C%20me%20interesan%20tus%20capacitaciones%20por%20Zoom"
          class="btn-primary"
          target="_blank"
          rel="noopener"
        >
          Consultá por WhatsApp
        </a>
        <a href="https://calendly.com/valeriayashan/30min" class="btn-secondary" target="_blank" rel="noopener">
          Agendá una llamada gratuita
        </a>
      </div>
    </div>
  </section>

  <!-- CAPACITACIONES DISPONIBLES -->
  <section class="cap-oferta">
    <div class="cap-inner">
      <h2 class="cap-section-titulo">¿Qué capacitaciones ofrezco?</h2>
      <p class="cap-section-sub">
        Todas las capacitaciones se dictan en vivo por Zoom, en grupos reducidos,
        con materiales incluidos y acceso a la grabación de cada sesión.
      </p>

      <div class="cap-oferta-grid">

        <div class="cap-oferta-card">
          <div class="cap-oferta-num">01</div>
          <div class="cap-formato-badge">8 sesiones · 2h c/u · Vivo por Zoom</div>
          <h3 class="cap-oferta-titulo">Preparación para el examen PMP®</h3>
          <p class="cap-oferta-desc">
            Preparate para rendir y aprobar la certificación más reconocida en gestión de proyectos a nivel mundial.
            Cubrimos el PMBOK 8, el ECO 2026, simulacros de examen y estrategia concreta para el día del examen.
          </p>
          <ul class="cap-oferta-lista">
            <li>PMBOK 8 y ECO 2026 actualizados</li>
            <li>Simulacros con preguntas reales</li>
            <li>Estrategia para el examen</li>
            <li>Acompañamiento en la inscripción al PMI</li>
          </ul>
          <a
            href="https://wa.me/541140791007?text=Hola%20Valeria%2C%20me%20interesa%20la%20capacitaci%C3%B3n%20de%20Preparaci%C3%B3n%20PMP%C2%AE"
            class="cap-oferta-cta"
            target="_blank"
            rel="noopener"
          >
            Consultá disponibilidad →
          </a>
        </div>

        <div class="cap-oferta-card">
          <div class="cap-oferta-num">02</div>
          <div class="cap-formato-badge">4 sesiones · 2h c/u · Vivo por Zoom</div>
          <h3 class="cap-oferta-titulo">IA aplicada para Project Managers</h3>
          <p class="cap-oferta-desc">
            Aprendé a usar inteligencia artificial de forma concreta en tu trabajo diario como PM.
            Prompts reales, flujos de trabajo con IA y herramientas aplicadas a la gestión de proyectos.
          </p>
          <ul class="cap-oferta-lista">
            <li>Prompts aplicados al trabajo de PM</li>
            <li>Automatización de tareas repetitivas</li>
            <li>IA para reportes y seguimiento</li>
            <li>Herramientas reales, no teoría</li>
          </ul>
          <a
            href="https://wa.me/541140791007?text=Hola%20Valeria%2C%20me%20interesa%20la%20capacitaci%C3%B3n%20de%20IA%20para%20Project%20Managers"
            class="cap-oferta-cta"
            target="_blank"
            rel="noopener"
          >
            Consultá disponibilidad →
          </a>
        </div>

        <div class="cap-oferta-card">
          <div class="cap-oferta-num">03</div>
          <div class="cap-formato-badge">A medida · Grupos cerrados · Vivo por Zoom</div>
          <h3 class="cap-oferta-titulo">Gestión de Proyectos para equipos</h3>
          <p class="cap-oferta-desc">
            Capacitación práctica para equipos que quieren estructurar su forma de trabajar.
            Definición de roles, herramientas de seguimiento y metodologías adaptadas a la realidad del equipo.
          </p>
          <ul class="cap-oferta-lista">
            <li>Metodologías predictivas, ágiles e híbridas</li>
            <li>Definición de roles y responsabilidades</li>
            <li>Herramientas de planificación y seguimiento</li>
            <li>Adaptado al contexto de tu equipo</li>
          </ul>
          <a
            href="https://wa.me/541140791007?text=Hola%20Valeria%2C%20me%20interesa%20la%20capacitaci%C3%B3n%20de%20Gesti%C3%B3n%20de%20Proyectos%20para%20equipos"
            class="cap-oferta-cta"
            target="_blank"
            rel="noopener"
          >
            Consultá disponibilidad →
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- TESTIMONIOS -->
  <section class="cap-testimonios">
    <div class="cap-inner">
      <h2 class="cap-section-titulo">Lo que dicen quienes ya pasaron por acá</h2>
      <div class="cap-testimonios-grid">

        <div class="cap-testimonio">
          <p class="cap-testimonio-texto">"Aprobé el PMP en el primer intento. La preparación con Valeria fue clave — no solo el contenido, sino la estrategia para el día del examen."</p>
          <div class="cap-testimonio-autor">
            <div class="cap-testimonio-avatar">MG</div>
            <div>
              <p class="cap-testimonio-nombre">M. González</p>
              <p class="cap-testimonio-rol">Project Manager · Argentina</p>
            </div>
          </div>
        </div>

        <div class="cap-testimonio">
          <p class="cap-testimonio-texto">"Empecé a usar IA en mis proyectos desde la primera sesión. No es teoría: cada ejercicio lo apliqué directamente a mi trabajo real."</p>
          <div class="cap-testimonio-autor">
            <div class="cap-testimonio-avatar">LR</div>
            <div>
              <p class="cap-testimonio-nombre">L. Rodríguez</p>
              <p class="cap-testimonio-rol">Líder de proyectos · España</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- POR QUÉ ZOOM -->
  <section class="cap-zoom">
    <div class="cap-inner">
      <h2 class="cap-section-titulo">¿Por qué en vivo por Zoom?</h2>

      <div class="cap-zoom-grid">
        <div class="cap-zoom-item">
          <div class="cap-zoom-icono"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg></div>
          <h3 class="cap-zoom-titulo">Sin límites geográficos</h3>
          <p class="cap-zoom-desc">Participan profesionales de Argentina, LATAM y España en la misma sesión.</p>
        </div>
        <div class="cap-zoom-item">
          <div class="cap-zoom-icono"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
          <h3 class="cap-zoom-titulo">Grupos reducidos</h3>
          <p class="cap-zoom-desc">Grupos pequeños para que puedas preguntar, participar y recibir atención real.</p>
        </div>
        <div class="cap-zoom-item">
          <div class="cap-zoom-icono"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg></div>
          <h3 class="cap-zoom-titulo">Con grabación incluida</h3>
          <p class="cap-zoom-desc">Si no podés asistir a una sesión, tenés acceso a la grabación para no perderte nada.</p>
        </div>
        <div class="cap-zoom-item">
          <div class="cap-zoom-icono"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></div>
          <h3 class="cap-zoom-titulo">Acompañamiento directo</h3>
          <p class="cap-zoom-desc">Acceso a Valeria para consultas entre sesiones, sin intermediarios.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ACCESO A SESIONES — para alumnos activos -->
  <section class="cap-acceso">
    <div class="cap-inner">
      <h2 class="cap-section-titulo">¿Ya estás inscripto/a?</h2>
      <p class="cap-section-sub">
        Si ya sos alumno/a, el link de Zoom de cada sesión te llega por email antes de cada clase.
        Si no lo recibiste, escribime por WhatsApp y te lo reenvío de inmediato.
      </p>

      <div class="cap-acceso-box">
        <div class="cap-acceso-icono"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></div>
        <div class="cap-acceso-texto">
          <p class="cap-acceso-titulo">El link de Zoom llega por email antes de cada sesión</p>
          <p class="cap-acceso-desc">
            Revisá tu bandeja de entrada (y la carpeta de spam) antes de la clase.
            Si tenés algún problema para acceder, escribime con tiempo.
          </p>
        </div>
        <a
          href="https://wa.me/541140791007?text=Hola%20Valeria%2C%20no%20recib%C3%AD%20el%20link%20de%20Zoom%20para%20mi%20clase"
          class="btn-primary"
          target="_blank"
          rel="noopener"
        >
          No recibí el link
        </a>
      </div>

    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="cap-cta-final">
    <div class="cap-inner">
      <h2 class="cap-cta-titulo">¿Cuándo arranca la próxima cohorte?</h2>
      <p class="cap-cta-sub">
        Escribime y te cuento las fechas disponibles. Los grupos son reducidos y los cupos se llenan rápido.
      </p>
      <div class="cap-cta-btns">
        <a
          href="https://wa.me/5491140791007?text=Hola%20Valeria%2C%20quiero%20saber%20las%20fechas%20de%20la%20pr%C3%B3xima%20cohorte"
          class="cap-btn-verde-blanco"
          target="_blank"
          rel="noopener"
        >
          Consultame por WhatsApp
        </a>
        <a href="https://calendly.com/valeriayashan/30min" class="cap-btn-outline-blanco" target="_blank" rel="noopener">
          Agendá una llamada gratuita
        </a>
      </div>
      <p class="cap-cta-garantia">Te respondo en menos de 24 horas.</p>
    </div>
  </section>

</BaseLayout>

<style>
  /* ─── Variables del sistema de diseño ─── */
  /* Usa las CSS vars ya definidas en global.css:
     --color-accent: #2D6A4F
     --color-bg: #FAFAF8
     --color-surface: #F2F1EE
     --color-text: #1A1A1A
     --color-muted: #6B6B6B
     --color-border: #E0DFDB
  */

  /* ─── Contenedor base ─── */
  .cap-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ─── Títulos de sección ─── */
  .cap-section-titulo {
    font-family: 'Fraunces', serif;
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.75rem;
    line-height: 1.25;
  }

  .cap-section-sub {
    font-size: 1rem;
    color: var(--color-muted);
    line-height: 1.6;
    max-width: 600px;
    margin-bottom: 2rem;
  }

  /* ─── Botones ─── */
  .btn-primary {
    display: inline-block;
    background: var(--color-accent);
    color: #fff;
    padding: 0.75rem 1.5rem;
    border-radius: 6px;
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .btn-primary:hover {
    opacity: 0.88;
  }

  .btn-secondary {
    display: inline-block;
    background: transparent;
    color: var(--color-accent);
    padding: 0.7rem 1.5rem;
    border-radius: 6px;
    border: 1.5px solid var(--color-accent);
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s;
  }

  .btn-secondary:hover {
    background: var(--color-surface);
  }

  /* ─── HERO ─── */
  .cap-hero {
    padding: 4rem 1.5rem 3rem;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .cap-hero-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .cap-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .cap-hero-titulo {
    font-family: 'Fraunces', serif;
    font-size: 2.5rem;
    font-weight: 900;
    color: var(--color-text);
    line-height: 1.15;
    margin-bottom: 1rem;
    max-width: 600px;
  }

  .cap-hero-sub {
    font-size: 1rem;
    color: var(--color-muted);
    line-height: 1.7;
    max-width: 560px;
    margin-bottom: 1.75rem;
  }

  .cap-hero-btns {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  /* ─── OFERTA ─── */
  .cap-oferta {
    padding: 4rem 1.5rem;
    background: var(--color-bg);
  }

  .cap-oferta-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 900px) {
    .cap-oferta-grid {
      grid-template-columns: 1fr;
    }
  }

  .cap-oferta-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: border-color 0.2s;
  }

  .cap-oferta-card:hover {
    border-color: var(--color-accent);
  }

  .cap-oferta-num {
    font-family: 'Fraunces', serif;
    font-size: 2rem;
    font-weight: 900;
    color: var(--color-accent);
    opacity: 0.3;
    line-height: 1;
  }

  .cap-oferta-titulo {
    font-family: 'Inter', sans-serif;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
  }

  .cap-oferta-desc {
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.6;
    flex: 1;
  }

  .cap-oferta-lista {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .cap-oferta-lista li {
    font-size: 0.875rem;
    color: var(--color-muted);
    padding-left: 1.1rem;
    position: relative;
  }

  .cap-oferta-lista li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-size: 0.8rem;
  }

  .cap-oferta-cta {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    margin-top: 0.5rem;
  }

  .cap-oferta-cta:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ─── ACCESO ALUMNOS ─── */
  .cap-acceso {
    padding: 4rem 1.5rem;
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .cap-acceso-box {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.5rem 2rem;
    flex-wrap: wrap;
  }

  .cap-acceso-icono {
    font-size: 2rem;
    flex-shrink: 0;
  }

  .cap-acceso-texto {
    flex: 1;
    min-width: 200px;
  }

  .cap-acceso-titulo {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.25rem;
  }

  .cap-acceso-desc {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.5;
  }

  /* ─── POR QUÉ ZOOM ─── */
  .cap-zoom {
    padding: 4rem 1.5rem;
    background: var(--color-bg);
  }

  .cap-zoom-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 900px) {
    .cap-zoom-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 500px) {
    .cap-zoom-grid {
      grid-template-columns: 1fr;
    }
  }

  .cap-zoom-item {
    padding: 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
  }

  .cap-zoom-icono {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .cap-zoom-titulo {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.4rem;
  }

  .cap-zoom-desc {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.55;
  }

  /* ─── CTA FINAL ─── */
  .cap-cta-final {
    padding: 4rem 1.5rem;
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    text-align: center;
  }

  .cap-cta-titulo {
    font-family: 'Fraunces', serif;
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }

  .cap-cta-sub {
    font-size: 1rem;
    color: var(--color-muted);
    margin-bottom: 1.75rem;
    line-height: 1.6;
  }

  .cap-cta-btns {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ─── BADGES DE FORMATO ─── */
  .cap-formato-badge {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent);
    background: #E8F4EE;
    padding: 3px 10px;
    border-radius: 20px;
    margin-bottom: 0.25rem;
  }

  /* ─── TESTIMONIOS ─── */
  .cap-testimonios {
    padding: 4rem 1.5rem;
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
  }

  .cap-testimonios-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  @media (max-width: 700px) {
    .cap-testimonios-grid {
      grid-template-columns: 1fr;
    }
  }

  .cap-testimonio {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .cap-testimonio-texto {
    font-size: 0.975rem;
    color: var(--color-text);
    line-height: 1.7;
    font-style: italic;
    margin: 0;
    flex: 1;
  }

  .cap-testimonio-autor {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .cap-testimonio-avatar {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: var(--color-accent);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .cap-testimonio-nombre {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0;
  }

  .cap-testimonio-rol {
    font-size: 0.8rem;
    color: var(--color-muted);
    margin: 0;
  }

  /* ─── ÍCONOS SVG en "¿Por qué Zoom?" ─── */
  .cap-zoom-icono {
    width: 44px;
    height: 44px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  /* ─── CTA FINAL VERDE ─── */
  .cap-cta-final {
    padding: 4rem 1.5rem;
    background: var(--color-accent);
    border-top: 1px solid var(--color-border);
    text-align: center;
