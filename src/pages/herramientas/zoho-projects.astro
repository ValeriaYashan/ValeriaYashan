            <div class="comp-col comp-no">No</div>
            <div class="comp-col comp-no">No</div>
            <div class="comp-col comp-medio">Parcial</div>
          </div>

          <div class="comparativa-fila">
            <div class="comp-col comp-feature">Curva de aprendizaje</div>
            <div class="comp-col comp-medio">Media</div>
            <div class="comp-col comp-si">Baja</div>
