---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection, render } from 'astro:content';

const allPosts = await getCollection('blog');

const posts = await Promise.all(
  allPosts
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .map(async (post) => {
      const plainText = post.body ?? '';
      const wordCount = plainText.trim().split(/\s+/).length;
      const readingTime = Math.max(1, Math.round(wordCount / 200));
      return { post, readingTime };
    })
);
---

<BaseLayout
  title="Blog — Valeria Yashan"
  description="Artículos de Valeria Yashan sobre Project Management, IA aplicada, productividad y herramientas digitales."
>
  <div class="container page-container">

    <header class="page-header">
      <p class="page-eyebrow">Blog</p>
      <h1>Artículos</h1>
      <p class="page-lead">
        Escribo sobre gestión de proyectos, inteligencia artificial aplicada,
        productividad y herramientas digitales. Sin relleno, con ejemplos concretos.
      </p>
    </header>

    <section class="posts-grid">
      {posts.map(({ post, readingTime }) => (
        <ArticleCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          category={post.data.category}
          slug={post.id.replace(/\.md$/, '')}
          readingTime={readingTime}
        />
      ))}
    </section>

    <section class="blog-newsletter">
      <p class="newsletter-label">Newsletter</p>
      <h2 class="newsletter-titulo">Recibí los próximos artículos</h2>
      <p class="newsletter-desc">Sin spam. Solo cuando publico algo que vale la pena leer.</p>
      <a href="/recursos#newsletter" class="btn-newsletter">Suscribirme →</a>
    </section>

  </div>
</BaseLayout>

<style>
  .page-container {
    padding-top: var(--space-lg);
    padding-bottom: var(--space-xl);
  }

  .page-header {
    margin-bottom: var(--space-lg);
    max-width: 600px;
  }

  .page-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  .page-lead {
    font-size: 1.1rem;
    color: var(--color-muted);
    margin-top: var(--space-sm);
    margin-bottom: 0;
    line-height: 1.7;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    max-width: 900px;
    margin-bottom: var(--space-lg);
  }

  .blog-newsletter {
    max-width: 900px;
    margin-top: var(--space-lg);
    padding: 2rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    border-left: 3px solid var(--color-accent);
  }

  .newsletter-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: 0.4rem;
  }

  .newsletter-titulo {
    font-family: 'Fraunces', serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.4rem;
  }

  .newsletter-desc {
    color: var(--color-muted);
    font-size: 0.92rem;
    margin-bottom: 1rem;
  }

  .btn-newsletter {
    display: inline-block;
    background: var(--color-accent);
    color: #fff;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    padding: 0.65rem 1.4rem;
    border-radius: 6px;
    text-decoration: none;
    transition: background 0.2s ease;
  }

  .btn-newsletter:hover {
    background: #1B4332;
  }

  @media (max-width: 700px) {
    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>