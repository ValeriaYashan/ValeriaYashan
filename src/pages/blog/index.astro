---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title="Blog"
  description="Artículos de Valeria Yashan sobre Project Management, IA aplicada, productividad y herramientas digitales."
>
  <div class="container page-container">
    <header class="page-header mark-accent">
      <p class="page-eyebrow">Blog</p>
      <h1>Artículos</h1>
      <p class="page-lead">
        Escribo sobre gestión de proyectos, inteligencia artificial aplicada,
        productividad y herramientas digitales. Sin relleno, con ejemplos concretos.
      </p>
    </header>

    <section class="posts-list">
      {posts.map(post => (
        <ArticleCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          category={post.data.category}
          slug={post.id.replace(/\.md$/, '')}
        />
      ))}
    </section>
  </div>
</BaseLayout>

<style>
  .page-container {
    padding-top: var(--space-lg);
    padding-bottom: var(--space-xl);
  }

  .page-header {
    margin-bottom: var(--space-lg);
  }

  .page-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  .page-lead {
    font-size: 1.1rem;
    color: var(--color-muted);
    margin-top: var(--space-sm);
    margin-bottom: 0;
    max-width: 520px;
  }
</style>