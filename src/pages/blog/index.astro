---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');

const posts = await Promise.all(
  allPosts
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .map(async (post) => {
      const plainText = post.body ?? '';
      const wordCount = plainText.trim().split(/\s+/).length;
      const readingTime = Math.max(1, Math.round(wordCount / 200));
      return { post, readingTime };
    })
);

const categories = ['Todos', ...new Set(posts.map(p => p.post.data.category))];
---

<BaseLayout
  title="Blog — Valeria Yashan"
  description="Artículos de Valeria Yashan sobre Project Management, IA aplicada, productividad y herramientas digitales."
>
  <div class="container page-container">

    <header class="page-header">
      <p class="page-eyebrow">Blog</p>
      <h1>Artículos</h1>
      <p class="page-lead">
        Escribo sobre gestión de proyectos, inteligencia artificial aplicada,
        productividad y herramientas digitales. Sin relleno, con ejemplos concretos.
      </p>
    </header>

    <div class="filter-bar">
      {categories.map(cat => (
        <button
          class="filter-btn"
          data-category={cat}
          aria-pressed={cat === 'Todos' ? 'true' : 'false'}
        >
          {cat}
        </button>
      ))}
    </div>

    <section class="posts-grid" id="posts-grid">
      {posts.map(({ post, readingTime }) => (
        <div class="post-wrapper" data-category={post.data.category}>
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            tags={post.data.tags ?? []}
            slug={post.id.replace(/\.md$/, '')}
            readingTime={readingTime}
          />
        </div>
      ))}
    </section>

    <section class="blog-newsletter">
      <p class="newsletter-label">Newsletter</p>
      <h2 class="newsletter-titulo">Recibí los próximos artículos</h2>
      <p class="newsletter-desc">Sin spam. Solo cuando publico algo que vale la pena leer.</p>
      <a href="/recursos#newsletter" class="btn-newsletter">Suscribirme →</a>
    </section>

  </div>
</BaseLayout>

<script>
  (function () {
    const buttons = document.querySelectorAll('.filter-btn');
    const wrappers = document.querySelectorAll('.post-wrapper');

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const selected = btn.getAttribute('data-category');

        buttons.forEach(b => b.setAttribute('aria-pressed', 'false'));
        btn.setAttribute('aria-pressed', 'true');

        wrappers.forEach(wrapper => {
          const cat = wrapper.getAttribute('data-category');
          if (selected === 'Todos' || cat === selected) {
            wrapper.style.display = 'block';
          } else {
            wrapper.style.display = 'none';
          }
        });
      });
    });
  })();
</script>

<style>
  .page-container {
    padding-top: var(--space-lg);
    padding-bottom: var(--space-xl);
  }

  .page-header {
    margin-bottom: var(--space-lg);
    max-width: 600px;
  }

  .page-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  .page-lead {
    font-size: 1.1rem;
    color: var(--color-muted);
    margin-top: var(--space-sm);
    margin-bottom: 0;
    line-height: 1.7;
  }

  .filter-bar {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    max-width: 900px;
  }

  .filter-btn {
    font-family: 'Inter', sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    padding: 0.45rem 1rem;
    border-radius: 20px;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-muted);
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .filter-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .filter-btn[aria-pressed="true"] {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #ffffff;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    max-width: 900px;
    margin-bottom: var(--space-lg);
  }

  .blog-newsletter {
    max-width: 900px;
    margin-top: var(--space-lg);
    padding: 2rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    border-left: 3px solid var(--color-accent);
  }

  .newsletter-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: 0.4rem;
  }

  .newsletter-titulo {
    font-family: 'Fraunces', serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.4rem;
  }

  .newsletter-desc {
    color: var(--color-muted);
    font-size: 0.92rem;
    margin-bottom: 1rem;
  }

  .btn-newsletter {
    display: inline-block;
    background: var(--color-accent);
    color: #fff;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    padding: 0.65rem 1.4rem;
    border-radius: 6px;
    text-decoration: none;
    transition: background 0.2s ease;
  }

  .btn-newsletter:hover {
    background: #1B4332;
  }

  @media (max-width: 700px) {
    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>