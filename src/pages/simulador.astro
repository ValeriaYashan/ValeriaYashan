---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Simulador PMP® 2026 | Valeria Yashan";
const description = "Practicá preguntas reales del examen PMP® alineadas al ECO 2026. Dos modos: banco de preguntas con feedback inmediato o simulacro cronometrado. Basado en los libros de Valeria Yashan, PMP®.";
---

<BaseLayout title={title} description={description}>
  <main class="simulador-wrap">

    <!-- INTRO -->
    <div id="intro-screen">
      <div class="intro-eyebrow">Simulador gratuito · ECO 2026</div>
      <h1 class="intro-title">Practicá para el PMP®</h1>
      <p class="intro-desc">10 preguntas seleccionadas del <em>Tomo III — Simulacros de Práctica Intensiva</em>. Distribución real: Personas · Proceso · Entorno de negocio.</p>

      <div class="exam-info-bar">
        <div class="ei-item">
          <span class="ei-num">180</span>
          <span class="ei-label">preguntas en el examen real</span>
        </div>
        <div class="ei-sep"></div>
        <div class="ei-item">
          <span class="ei-num">230</span>
          <span class="ei-label">minutos disponibles</span>
        </div>
        <div class="ei-sep"></div>
        <div class="ei-item">
          <span class="ei-num">~AT</span>
          <span class="ei-label">puntaje mínimo por dominio</span>
        </div>
        <div class="ei-sep"></div>
        <div class="ei-item">
          <span class="ei-num">Sin</span>
          <span class="ei-label">penalización por error</span>
        </div>
      </div>

      <p class="intro-strategy">
        <strong>Estrategia recomendada:</strong> empezá con el banco de preguntas para identificar tus brechas por dominio. Cuando llegues al 80% en los tres dominios, pasá al modo simulacro cronometrado.
      </p>

      <div class="mode-grid">
        <div class="mode-card mode-banco">
          <div class="mode-step">Paso 1 · Empezá aquí</div>
          <div class="mode-icon">📖</div>
          <div class="mode-title">Banco de preguntas</div>
          <p class="mode-desc">Una pregunta por vez. Feedback inmediato con la explicación completa. Ideal para aprender, repasar y detectar brechas sin presión de tiempo.</p>
          <button class="btn-mode btn-banco" onclick="startMode('banco')">Empezar a estudiar →</button>
        </div>
        <div class="mode-card mode-simulacro">
          <div class="mode-step">Paso 2 · Cuando te sintás listo</div>
          <div class="mode-icon">⏱</div>
          <div class="mode-title">Simulacro de examen</div>
          <p class="mode-desc">10 preguntas · 15 minutos · sin feedback hasta el final. La misma presión del examen real. Resultado con diagnóstico por dominio.</p>
          <button class="btn-mode btn-simulacro" onclick="startMode('simulacro')">Simular examen →</button>
        </div>
      </div>

      <p class="intro-hint">¿Querés el banco completo de 180 preguntas? <a href="/libro">Conocé el Tomo III</a></p>
    </div>

    <!-- QUIZ -->
    <div id="quiz-screen" style="display:none">
      <div class="quiz-topbar">
        <button class="btn-back" onclick="goBack()">← Volver</button>
        <div class="quiz-mode-label" id="quiz-mode-label">Banco de preguntas</div>
        <div class="timer-wrap" id="timer-wrap" style="display:none">
          <span class="timer-icon">⏱</span>
          <span id="timer-display">15:00</span>
        </div>
      </div>

      <div class="quiz-header">
        <div class="quiz-progress-text">
          <span id="q-counter">Pregunta 1 de 10</span>
          <span class="quiz-domain-badge" id="q-domain">Personas</span>
        </div>
        <div class="progress-bar">
          <div class="progress-fill" id="progress-fill" style="width:10%"></div>
        </div>
      </div>

      <div class="quiz-meta">
        <span class="meta-pill" id="q-tipo">Situacional</span>
        <span class="meta-pill dif-avanzada" id="q-dif">★ Avanzada</span>
        <span class="meta-pill meta-id" id="q-id">PMP-22-001</span>
      </div>

      <p class="question-text" id="q-text"></p>

      <div class="options-list" id="options-list"></div>

      <div class="feedback-box" id="feedback-box" style="display:none">
        <div class="feedback-header" id="feedback-header"></div>
        <p class="feedback-body" id="feedback-body"></p>
      </div>

      <div class="quiz-actions">
        <button class="btn-confirm" id="btn-confirm" onclick="confirmAnswer()" disabled>Confirmar respuesta</button>
        <button class="btn-next" id="btn-next" onclick="nextQuestion()" style="display:none">Siguiente →</button>
      </div>
    </div>

    <!-- RESULTADO -->
    <div id="result-screen" style="display:none">
      <div class="result-header">
        <div class="result-pct" id="result-pct">80%</div>
        <div class="result-sub" id="result-sub">8 de 10 correctas</div>
        <div class="result-mode-label" id="result-mode-label">Banco de preguntas</div>
      </div>

      <div class="result-msg" id="result-msg"></div>

      <div class="domain-grid">
        <div class="domain-card">
          <div class="d-name">Personas</div>
          <div class="d-pct" id="dp-personas">—</div>
          <div class="d-diag" id="dd-personas">—</div>
        </div>
        <div class="domain-card">
          <div class="d-name">Proceso</div>
          <div class="d-pct" id="dp-proceso">—</div>
          <div class="d-diag" id="dd-proceso">—</div>
        </div>
        <div class="domain-card">
          <div class="d-name">Entorno</div>
          <div class="d-pct" id="dp-entorno">—</div>
          <div class="d-diag" id="dd-entorno">—</div>
        </div>
      </div>

      <div class="result-actions">
        <button class="btn-retry" onclick="retryMode()">Repetir este modo</button>
        <button class="btn-switch" id="btn-switch" onclick="switchMode()">Probar el otro modo →</button>
      </div>
      <div class="result-ctas">
        <a class="btn-libro" href="/libro">Ver el Tomo III completo →</a>
        <a class="btn-consulta" href="https://calendly.com/valeriayashan/30min" target="_blank" rel="noopener">Hablemos sobre tu preparación</a>
      </div>
    </div>

  </main>
</BaseLayout>

<script is:inline>
const PREGUNTAS = [
  {
    id: "PMP-22-001", dominio: "Personas", tipo: "Situacional", dificultad: "avanzada",
    texto: "Liderás un equipo híbrido de 14 personas distribuidas entre Colombia, Chile y México. Tres meses después del inicio, la analista senior informa que dos integrantes se sienten excluidos de las decisiones técnicas, aunque participan en las ceremonias ágiles. Hasta ahora habías asumido que la participación en dailys era suficiente para mantener la integración. ¿Qué debés hacer?",
    opciones: { A: "Ampliar el tiempo de las dailys para incluir rondas de opinión de todos los integrantes.", B: "Facilitar conversaciones individuales con los integrantes afectados para entender sus perspectivas y redefinir su rol en las decisiones técnicas.", C: "Informar al sponsor que el equipo requiere reorganización para resolver problemas de integración.", D: "Documentar el incidente como un riesgo de equipo y aplicar el plan de respuesta de riesgos." },
    correcta: "B",
    explicacion: "La exclusión percibida de decisiones técnicas es un problema de integración y confianza, no de tiempo en reuniones. El director debe escuchar directamente a los afectados antes de tomar medidas."
  },
  {
    id: "PMP-22-003", dominio: "Personas", tipo: "Situacional", dificultad: "avanzada",
    texto: "Sos responsable del desarrollo de un sistema de trazabilidad de medicamentos en una farmacéutica de Buenos Aires, regulado por ANMAT. El equipo técnico toma decisiones de arquitectura sin documentarlas ni comunicarlas, generando impactos en el alcance y plazos no previstos. Un integrante senior argumenta que la documentación ralentiza al equipo. ¿Cuál es la mejor respuesta?",
    opciones: { A: "Acordar con el equipo un mecanismo liviano de registro de decisiones técnicas con impacto, sin ralentizar la velocidad de entrega.", B: "Exigir que todas las decisiones técnicas sean aprobadas por la directora antes de implementarse.", C: "Escalar al PMO para que establezca estándares de documentación aplicables al equipo técnico.", D: "Aceptar el argumento del equipo senior y confiar en que comunicarán los impactos cuando sean relevantes." },
    correcta: "A",
    explicacion: "El desafío es equilibrar la autonomía técnica con la gobernanza en un proyecto regulado. Un mecanismo liviano (como un ADR) permite capturar decisiones con impacto sin convertir la documentación en un cuello de botella."
  },
  {
    id: "PMP-22-005", dominio: "Personas", tipo: "Situacional", dificultad: "avanzada",
    texto: "Dos ingenieros senior de tu equipo en Ciudad de México tienen un conflicto recurrente sobre la arquitectura del sistema. Los debates se extienden en las dailys más allá del tiempo asignado. Ya intentaste mediar en dos reuniones previas sin llegar a un acuerdo. El sprint vence en cuatro días. ¿Qué debés hacer?",
    opciones: { A: "Tomar una decisión técnica definitiva basándote en tu criterio y comunicarla al equipo como política del proyecto.", B: "Establecer un criterio de decisión técnica acordado con ambos ingenieros y el equipo, y definir quién tiene la última palabra en ausencia de consenso.", C: "Separar a los dos ingenieros en subequipos diferentes para evitar que el conflicto continúe.", D: "Solicitar al sponsor que intervenga para mediar entre los dos ingenieros senior." },
    correcta: "B",
    explicacion: "Cuando la mediación directa no produce consenso, el paso correcto es establecer un mecanismo de resolución de disputas técnicas: definir criterios y quién tiene autoridad de cierre. Esto es gobernanza del equipo, no imposición."
  },
  {
    id: "PMP-22-009", dominio: "Personas", tipo: "Conceptual", dificultad: "intermedia",
    texto: "¿Qué distingue a un equipo autogestionado de un equipo con autonomía operativa?",
    opciones: { A: "Un equipo autogestionado no necesita un director de proyectos; un equipo con autonomía operativa sí.", B: "Un equipo autogestionado decide cómo organizar su trabajo, quién hace qué y cómo resolver sus obstáculos, mientras que un equipo con autonomía operativa solo decide cómo ejecutar tareas definidas externamente.", C: "Un equipo autogestionado trabaja siempre con enfoque ágil; un equipo con autonomía operativa trabaja con enfoque predictivo.", D: "Un equipo autogestionado elimina la necesidad de retrospectivas porque resuelve sus problemas de forma continua." },
    correcta: "B",
    explicacion: "La diferencia clave es el alcance de la autonomía: un equipo autogestionado determina su organización interna, distribución de trabajo y mecanismos de resolución. La autonomía operativa solo cubre la ejecución de tareas definidas externamente."
  },
  {
    id: "PMP-22-022", dominio: "Proceso", tipo: "Cálculo", dificultad: "intermedia",
    texto: "Revisás los indicadores de valor ganado de un proyecto de manufactura al final del período 6.\n\nPV = 850.000 | EV = 720.000 | AC = 790.000\n\nFórmulas: SV = EV − PV | CV = EV − AC\n\n¿Cuál es la interpretación correcta?",
    opciones: { A: "El proyecto está adelantado en cronograma y por debajo del presupuesto.", B: "El proyecto está retrasado en cronograma y por encima del presupuesto.", C: "El proyecto está adelantado en cronograma y por encima del presupuesto.", D: "El proyecto está retrasado en cronograma y por debajo del presupuesto." },
    correcta: "B",
    explicacion: "SV = 720.000 − 850.000 = −130.000 (negativo = retraso). CV = 720.000 − 790.000 = −70.000 (negativo = por encima del presupuesto). Ambos indicadores negativos confirman la situación."
  },
  {
    id: "PMP-22-023", dominio: "Proceso", tipo: "Situacional", dificultad: "avanzada",
    texto: "Al inicio del Sprint 7, el Product Owner propone incorporar 5 historias de usuario de alta prioridad surgidas de un focus group reciente. El equipo tiene capacidad para 3 historias adicionales. El sprint ya está planificado. ¿Qué debés hacer?",
    opciones: { A: "Aceptar las cinco historias y extender el sprint dos semanas adicionales.", B: "Rechazar las cinco historias hasta el siguiente sprint sin análisis adicional.", C: "Facilitar con el PO la priorización de las historias nuevas contra el contenido actual del sprint, y proteger el sprint commitment del equipo.", D: "Agregar las cinco historias al sprint y reducir las historias originales planificadas para compensar." },
    correcta: "C",
    explicacion: "En Scrum, el Sprint Backlog protege el compromiso del equipo. Las historias nuevas deben ingresar al Product Backlog y competir en el próximo Sprint Planning. La directora facilita la conversación sin violar el sprint commitment."
  },
  {
    id: "PMP-22-030", dominio: "Proceso", tipo: "Situacional", dificultad: "avanzada",
    texto: "Liderás un proyecto de construcción al mes 8 de 18.\n\nBAC = 2.400.000 | EAC = 3.100.000 | ETC = 1.850.000\n\nFórmulas: EAC = BAC/CPI | ETC = EAC − AC\n\nEl sponsor pregunta si es viable completar dentro del presupuesto original. ¿Qué le respondés?",
    opciones: { A: "No, la estimación actual al completar (EAC) supera el presupuesto en 700.000. Se requiere una acción correctiva para reducir el costo remanente.", B: "Sí, el ETC restante (1.850.000) es menor que el BAC (2.400.000), por lo que el proyecto puede completarse dentro del presupuesto.", C: "No es posible determinarlo con los datos disponibles sin conocer el SPI y el CPI actuales.", D: "Sí, si el equipo mejora su eficiencia en la segunda mitad, el EAC puede reducirse al BAC original." },
    correcta: "A",
    explicacion: "EAC = 3.100.000 > BAC = 2.400.000. La diferencia de 700.000 es el costo adicional proyectado. ETC es el costo restante estimado, no el total — la comparación correcta es siempre EAC vs. BAC."
  },
  {
    id: "PMP-22-041", dominio: "Proceso", tipo: "Situacional", dificultad: "basica",
    texto: "Estás cerrando un proyecto de desarrollo de software. El cliente aceptó formalmente todos los entregables. ¿Cuál de las siguientes actividades NO es parte del proceso de cierre?",
    opciones: { A: "Liberar formalmente los recursos del proyecto.", B: "Documentar las lecciones aprendidas.", C: "Iniciar la fase de planificación del siguiente proyecto.", D: "Archivar los documentos del proyecto en el repositorio organizacional." },
    correcta: "C",
    explicacion: "El proceso de cierre incluye: liberación de recursos, lecciones aprendidas y archivo de documentación. Iniciar la planificación del siguiente proyecto corresponde a un proyecto diferente, no al cierre del actual."
  },
  {
    id: "PMP-22-050", dominio: "Entorno de negocio", tipo: "Conceptual", dificultad: "intermedia",
    texto: "Al evaluar si un nuevo proyecto debe iniciarse, ¿cuál describe correctamente el propósito del caso de negocio?",
    opciones: { A: "El caso de negocio documenta los requisitos del proyecto para que el equipo los implemente.", B: "El caso de negocio justifica la necesidad del proyecto, documenta los beneficios esperados y sirve como base para la decisión de inversión.", C: "El caso de negocio define el cronograma y el presupuesto preliminar del proyecto.", D: "El caso de negocio es un documento que el director de proyectos actualiza durante la ejecución para reportar el estado." },
    correcta: "B",
    explicacion: "El caso de negocio justifica por qué el proyecto debe realizarse: explica el problema u oportunidad, analiza opciones y documenta los beneficios esperados. No es un documento de requisitos, cronograma ni reporte de estado."
  },
  {
    id: "PMP-22-049", dominio: "Entorno de negocio", tipo: "Situacional", dificultad: "intermedia",
    texto: "Gestionás un proyecto de expansión al e-commerce internacional. El caso de negocio proyecta un retorno del 180% en 24 meses. A mitad de la ejecución, el análisis actualizado indica que el retorno se redujo al 95% por cambios en tipo de cambio y aranceles. ¿Cuál es la acción correcta?",
    opciones: { A: "Continuar el proyecto ya que la inversión está comprometida y no puede recuperarse.", B: "Actualizar el caso de negocio con las nuevas proyecciones, presentarlo al sponsor y evaluar si el proyecto sigue siendo viable.", C: "Reducir el presupuesto del proyecto para mejorar el retorno ajustado.", D: "Solicitar al equipo financiero que revise las proyecciones hasta que el retorno vuelva al 180%." },
    correcta: "B",
    explicacion: "El caso de negocio debe revisarse cuando cambian las condiciones del entorno. El director actualiza las proyecciones y las presenta al sponsor para que decida con información actualizada. Continuar sin revisión es la falacia del costo hundido."
  }
];

let mode = 'banco';
let current = 0;
let selected = null;
let confirmed = false;
let resultados = [];
let timerInterval = null;
let timerSeconds = 900;

function startMode(m) {
  mode = m;
  current = 0;
  selected = null;
  confirmed = false;
  resultados = [];

  document.getElementById('intro-screen').style.display = 'none';
  document.getElementById('quiz-screen').style.display = 'block';
  document.getElementById('quiz-mode-label').textContent = m === 'banco' ? 'Banco de preguntas' : 'Simulacro de examen';

  if (m === 'simulacro') {
    timerSeconds = 900;
    document.getElementById('timer-wrap').style.display = 'flex';
    updateTimerDisplay();
    timerInterval = setInterval(() => {
      timerSeconds--;
      updateTimerDisplay();
      if (timerSeconds <= 0) {
        clearInterval(timerInterval);
        showResult();
      }
    }, 1000);
  } else {
    document.getElementById('timer-wrap').style.display = 'none';
  }

  renderQuestion();
}

function updateTimerDisplay() {
  const m = Math.floor(timerSeconds / 60);
  const s = timerSeconds % 60;
  const display = m + ':' + (s < 10 ? '0' : '') + s;
  const el = document.getElementById('timer-display');
  el.textContent = display;
  el.style.color = timerSeconds <= 120 ? '#A32D2D' : '';
}

function renderQuestion() {
  const q = PREGUNTAS[current];
  selected = null;
  confirmed = false;

  document.getElementById('q-counter').textContent = 'Pregunta ' + (current + 1) + ' de ' + PREGUNTAS.length;
  const badge = document.getElementById('q-domain');
  badge.textContent = q.dominio;
  const domSlug = q.dominio.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').replace(/\s+/g,'-');
  badge.className = 'quiz-domain-badge domain-' + domSlug;

  document.getElementById('progress-fill').style.width = (((current + 1) / PREGUNTAS.length) * 100) + '%';
  document.getElementById('q-tipo').textContent = q.tipo;

  const difMap = { avanzada: '★ Avanzada', intermedia: '· Intermedia', basica: '○ Básica' };
  const difEl = document.getElementById('q-dif');
  difEl.textContent = difMap[q.dificultad] || q.dificultad;
  difEl.className = 'meta-pill dif-' + q.dificultad;

  document.getElementById('q-id').textContent = q.id;
  document.getElementById('q-text').textContent = q.texto;

  const container = document.getElementById('options-list');
  container.innerHTML = '';
  Object.entries(q.opciones).forEach(([letra, texto]) => {
    const div = document.createElement('div');
    div.className = 'option-item';
    div.id = 'opt-' + letra;
    div.innerHTML = '<span class="opt-letter">' + letra + '</span><span class="opt-text">' + texto + '</span>';
    div.addEventListener('click', () => pickOption(letra));
    container.appendChild(div);
  });

  document.getElementById('feedback-box').style.display = 'none';
  const btnConfirm = document.getElementById('btn-confirm');
  const btnNext = document.getElementById('btn-next');
  btnConfirm.style.display = 'inline-flex';
  btnConfirm.disabled = true;
  btnNext.style.display = 'none';
}

function pickOption(letra) {
  if (confirmed) return;
  selected = letra;
  document.querySelectorAll('.option-item').forEach(el => el.classList.remove('selected'));
  document.getElementById('opt-' + letra).classList.add('selected');
  document.getElementById('btn-confirm').disabled = false;
}

function confirmAnswer() {
  if (!selected || confirmed) return;
  confirmed = true;
  const q = PREGUNTAS[current];
  const esCorrecta = selected === q.correcta;
  resultados.push({ dominio: q.dominio, correcta: esCorrecta });

  document.querySelectorAll('.option-item').forEach(el => el.classList.remove('selected'));

  if (mode === 'banco') {
    if (esCorrecta) {
      document.getElementById('opt-' + selected).classList.add('correct');
    } else {
      document.getElementById('opt-' + selected).classList.add('wrong');
      document.getElementById('opt-' + q.correcta).classList.add('correct');
    }
    const fb = document.getElementById('feedback-box');
    fb.style.display = 'block';
    fb.className = 'feedback-box ' + (esCorrecta ? 'fb-correct' : 'fb-wrong');
    document.getElementById('feedback-header').textContent = esCorrecta ? '✓ Respuesta correcta' : '✗ Incorrecta — la correcta es ' + q.correcta;
    document.getElementById('feedback-body').textContent = q.explicacion;
  } else {
    document.getElementById('opt-' + selected).classList.add(esCorrecta ? 'correct' : 'wrong');
  }

  document.getElementById('btn-confirm').style.display = 'none';
  const btnNext = document.getElementById('btn-next');
  btnNext.style.display = 'inline-flex';
  btnNext.textContent = current < PREGUNTAS.length - 1 ? 'Siguiente →' : 'Ver resultado →';
}

function nextQuestion() {
  current++;
  if (current < PREGUNTAS.length) {
    renderQuestion();
  } else {
    showResult();
  }
}

function showResult() {
  if (timerInterval) clearInterval(timerInterval);
  document.getElementById('quiz-screen').style.display = 'none';
  document.getElementById('result-screen').style.display = 'block';

  const total = resultados.length;
  const correctas = resultados.filter(r => r.correcta).length;
  const pct = Math.round((correctas / total) * 100);

  document.getElementById('result-pct').textContent = pct + '%';
  document.getElementById('result-sub').textContent = correctas + ' de ' + total + ' correctas';
  document.getElementById('result-mode-label').textContent = mode === 'banco' ? 'Banco de preguntas' : 'Simulacro de examen';

  let msg = '';
  if (pct >= 80) msg = 'Buen resultado. Dominás el contenido de este bloque. Probá el simulacro cronometrado si todavía no lo hiciste.';
  else if (pct >= 60) msg = 'Zona de riesgo. Repasá los dominios con menor puntaje antes de presentar el examen.';
  else msg = 'Necesitás refuerzo. Volvé a los Tomos I y II en los dominios con brechas y practicá de nuevo.';
  document.getElementById('result-msg').textContent = msg;

  const dominios = ['Personas', 'Proceso', 'Entorno de negocio'];
  const slugs = ['personas', 'proceso', 'entorno'];
  dominios.forEach((d, i) => {
    const pregs = resultados.filter(r => r.dominio === d);
    const slug = slugs[i];
    if (pregs.length === 0) {
      document.getElementById('dp-' + slug).textContent = '—';
      document.getElementById('dd-' + slug).textContent = 'Sin preguntas';
      return;
    }
    const pctD = Math.round((pregs.filter(r => r.correcta).length / pregs.length) * 100);
    document.getElementById('dp-' + slug).textContent = pctD + '%';
    let diag, cls;
    if (pctD >= 80) { diag = 'Consolidado ✓'; cls = 'diag-ok'; }
    else if (pctD >= 60) { diag = 'Zona de riesgo'; cls = 'diag-risk'; }
    else { diag = 'Refuerzo necesario'; cls = 'diag-low'; }
    const diagEl = document.getElementById('dd-' + slug);
    diagEl.textContent = diag;
    diagEl.className = 'd-diag ' + cls;
  });

  const btnSwitch = document.getElementById('btn-switch');
  btnSwitch.textContent = mode === 'banco' ? 'Probar simulacro cronometrado →' : 'Volver al banco de preguntas →';
}

function retryMode() {
  startMode(mode);
}

function switchMode() {
  startMode(mode === 'banco' ? 'simulacro' : 'banco');
}

function goBack() {
  if (timerInterval) clearInterval(timerInterval);
  document.getElementById('quiz-screen').style.display = 'none';
  document.getElementById('result-screen').style.display = 'none';
  document.getElementById('intro-screen').style.display = 'block';
}
