---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Página no encontrada — Valeria Yashan"
  description="La página que buscás no existe o fue movida."
>
  <section class="not-found">
    <div class="container">
      <div class="not-found-inner">
        <span class="not-found-numero">404</span>
        <h1 class="not-found-titulo">Página no encontrada</h1>
        <p class="not-found-desc">La página que buscás no existe o fue movida. Podés volver al inicio o explorar el contenido desde el menú.</p>
        <div class="not-found-acciones">
          <a href="/" class="btn btn-primary">Ir al inicio</a>
          <a href="/blog" class="btn btn-outline">Ver artículos</a>
          <a href="/contacto" class="btn btn-outline">Contactarme</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    padding: var(--space-xl) 0;
    min-height: 60vh;
    display: flex;
    align-items: center;
  }
  .not-found-inner {
    max-width: 520px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .not-found-numero {
    font-family: var(--font-display);
    font-size: 6rem;
    font-weight: 900;
    color: var(--color-border);
    line-height: 1;
  }
  .not-found-titulo {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
  }
  .not-found-desc {
    font-size: 1rem;
    color: var(--color-muted);
    line-height: 1.7;
    margin: 0;
  }
  .not-found-acciones {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }
</style>