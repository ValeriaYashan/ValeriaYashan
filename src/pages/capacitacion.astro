---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Capacitación en Project Management — Valeria Yashan"
  description="Programas de capacitación en Project Management e IA. Preparación PMP®, PM + IA aplicada y más. Valeria Yashan, PMP®."
>

  <!-- HEADER -->
  <section class="cap-header">
    <div class="container">
      <p class="section-eyebrow">Valeria Yashan — PMP®</p>
      <h1 class="cap-title">Capacitación en Project Management</h1>
      <p class="cap-subtitle">Programas diseñados para profesionales que quieren estructurar su práctica, certificarse con la nueva versión PMBOK 8 y/o incorporar IA en la gestión de proyectos.</p>
    </div>
  </section>

  <!-- STATS -->
  <section class="cap-stats">
    <div class="container">
      <div class="stats-row">
        <div class="stat">
          <div class="stat-num">+10</div>
          <div class="stat-label">años de experiencia</div>
        </div>
        <div class="stat">
          <div class="stat-num">PMP®</div>
          <div class="stat-label">certificada PMI</div>
        </div>
        <div class="stat">
          <div class="stat-num">100%</div>
          <div class="stat-label">online en vivo</div>
        </div>
      </div>
    </div>
  </section>

  <div class="container">
    <hr class="divider" />
  </div>

  <!-- CURSO DISPONIBLE -->
  <section class="cap-seccion">
    <div class="container">
      <p class="section-label">Último Curso disponible</p>

      <div class="card-featured">
        <span class="badge badge-open">Terminando</span>
        <h2 class="card-title">Preparación PMP®</h2>
        <p class="card-desc">De la teoría al examen. Con enfoque práctico y acompañamiento real durante todo el proceso.</p>

        <div class="meta-row">
          <div class="meta-item">
            <svg viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" fill="none"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            8 semanas
          </div>
          <div class="meta-item">
            <svg viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" fill="none"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            Clases en vivo + material asincrónico
          </div>
          <div class="meta-item">
            <svg viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" fill="none"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            Grupo reducido
          </div>
        </div>

        <div class="modulos">
          <div class="modulo-row">
            <div class="modulo-num">1</div>
            <div class="modulo-text">Marco conceptual del PMBOK y estructura del examen PMP</div>
          </div>
          <div class="modulo-row">
            <div class="modulo-num">2</div>
            <div class="modulo-text">Enfoques predictivo, ágil e híbrido — diferencias y aplicación práctica</div>
          </div>
          <div class="modulo-row">
            <div class="modulo-num">3</div>
            <div class="modulo-text">Simulacros guiados y técnica de lectura de preguntas</div>
          </div>
          <div class="modulo-row">
            <div class="modulo-num">4</div>
            <div class="modulo-text">Gestión de riesgos, costos y comunicaciones — temas clave del examen</div>
          </div>
          <div class="modulo-row">
            <div class="modulo-num">5</div>
            <div class="modulo-text">Plan de estudio personalizado y mentalidad para el día del examen</div>
          </div>
        </div>

        <div class="tags">
          <span class="tag">PMBOK® 7</span>
          <span class="tag">Agile</span>
          <span class="tag">Simulacros</span>
          <span class="tag">Acompañamiento individual</span>
        </div>

        <div class="btn-row">
          <a href="/contacto" class="btn btn-primary">Quiero anotarme →</a>
          <a href="/contacto" class="btn btn-outline">Consultá por fecha y precio</a>
        </div>
      </div>
    </div>
  </section>

  <div class="container">
    <hr class="divider" />
  </div>

  <!-- PRÓXIMAMENTE -->
  <section class="cap-seccion">
    <div class="container">
      <p class="section-label">Próximamente</p>

      <div class="soon-card">
        <div class="soon-info">
          <span class="badge badge-soon">En desarrollo</span>
          <h3 class="soon-title">PM + IA aplicada</h3>
          <p class="soon-desc">Cómo integrar herramientas de IA en cada fase del ciclo de vida de un proyecto.</p>
        </div>
        <a href="/contacto" class="btn btn-outline">Avisame cuando esté disponible</a>
      </div>

      <div class="soon-card">
        <div class="soon-info">
          <span class="badge badge-soon">En desarrollo</span>
          <h3 class="soon-title">Fundamentos de Project Management</h3>
          <p class="soon-desc">Para profesionales sin experiencia formal en gestión de proyectos.</p>
        </div>
        <a href="/contacto" class="btn btn-outline">Avisame cuando esté disponible</a>
      </div>
    </div>
  </section>

  <div class="container">
    <hr class="divider" />
  </div>

  <!-- CTA CORPORATIVO -->
  <section class="cap-cta">
    <div class="container">
      <div class="cta-inner">
        <h2 class="cta-titulo">¿Tu empresa necesita capacitar a su equipo?</h2>
        <p class="cta-desc">Diseño programas a medida para organizaciones. Escribime y lo charlamos.</p>
        <a href="/contacto" class="btn btn-primary">Contactar →</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* HEADER */
  .cap-header {
    padding: var(--space-xl) 0 var(--space-md);
  }

  .cap-title {
    font-family: var(--font-display);
    font-size: 2.2rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.2;
    margin-bottom: 0.75rem;
  }

  .cap-subtitle {
    font-size: 1.05rem;
    color: var(--color-muted);
    max-width: 560px;
    line-height: 1.7;
  }

  /* STATS */
  .cap-stats {
    padding-bottom: var(--space-md);
  }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
  }

  .stat {
    text-align: center;
    padding: 1.25rem 1rem;
  }

  .stat + .stat {
    border-left: 1px solid var(--color-border);
  }

  .stat-num {
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .stat-label {
    font-size: 0.75rem;
    color: var(--color-muted);
    margin-top: 4px;
  }

  /* DIVIDER */
  .divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-lg) 0;
  }

  /* SECTION LABEL */
  .section-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }

  /* SECCIÓN GENÉRICA */
  .cap-seccion {
    padding-bottom: var(--space-md);
  }

  /* BADGE */
  .badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 20px;
    margin-bottom: 10px;
  }

  .badge-open {
    background: #EAF3DE;
    color: #27500A;
  }

  .badge-soon {
    background: var(--color-surface);
    color: var(--color-muted);
    border: 1px solid var(--color-border);
  }

  /* CARD FEATURED */
  .card-featured {
    border: 2px solid var(--color-accent);
    border-radius: 12px;
    padding: 1.75rem;
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 4px;
  }

  .card-desc {
    font-size: 0.95rem;
    color: var(--color-muted);
    margin-bottom: 1.25rem;
  }

  /* META ROW */
  .meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.85rem;
    color: var(--color-muted);
  }

  .meta-item svg {
    width: 16px;
    height: 16px;
    stroke: var(--color-muted);
    flex-shrink: 0;
  }

  /* MÓDULOS */
  .modulos {
    margin-bottom: 1.5rem;
  }

  .modulo-row {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin-bottom: 10px;
  }

  .modulo-num {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-accent);
    font-size: 0.7rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .modulo-text {
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.5;
  }

  /* TAGS */
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 1.5rem;
  }

  .tag {
    font-size: 0.75rem;
    padding: 3px 10px;
    border-radius: 20px;
    background: var(--color-surface);
    color: var(--color-muted);
    border: 1px solid var(--color-border);
  }

  /* BOTONES */
  .btn-row {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  /* SOON CARDS */
  .soon-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .soon-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 3px;
  }

  .soon-desc {
    font-size: 0.85rem;
    color: var(--color-muted);
  }

  /* CTA CORPORATIVO */
  .cap-cta {
    padding-bottom: var(--space-xl);
  }

  .cta-inner {
    background: var(--color-surface);
    border-radius: 12px;
    padding: 2rem;
    text-align: center;
  }

  .cta-titulo {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .cta-desc {
    font-size: 0.95rem;
    color: var(--color-muted);
    margin-bottom: 1.25rem;
  }

  /* RESPONSIVE */
  @media (max-width: 700px) {
    .cap-title {
      font-size: 1.7rem;
    }

    .stats-row {
      grid-template-columns: repeat(3, 1fr);
    }

    .stat-num {
      font-size: 1.1rem;
    }

    .soon-card {
      flex-direction: column;
      align-items: flex-start;
    }

    .card-featured {
      padding: 1.25rem;
    }
  }
</style>