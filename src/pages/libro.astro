---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Mis libros — Valeria Yashan"
  description="Libros de Valeria Yashan sobre gestión de proyectos y certificación PMP. Disponibles en Amazon y en formato digital."
  image="/images/cover-tomo-1.webp"
  schema={{
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Libros de Valeria Yashan",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "item": {
          "@type": "Book",
          "name": "Dirección de Proyectos: Guía de Preparación para la Certificación PMP® — Tomo I",
          "author": { "@type": "Person", "name": "Valeria Yashan" },
          "url": "https://www.amazon.com/-/es/Valeria-Yashan-ebook/dp/B0H4J29PP5/",
          "inLanguage": "es",
          "genre": "Project Management"
        }
      },
      {
        "@type": "ListItem",
        "position": 2,
        "item": {
          "@type": "Book",
          "name": "Dirección de Proyectos: Procesos, Predictivo, Ágil e Híbrido — Tomo II",
          "author": { "@type": "Person", "name": "Valeria Yashan" },
          "url": "https://www.amazon.com/-/es/dp/B0H5DWJ5VM",
          "inLanguage": "es",
          "genre": "Project Management"
        }
      },
      {
        "@type": "ListItem",
        "position": 3,
        "item": {
          "@type": "Book",
          "name": "Dirección de Proyectos: Guía de Preparación para la Certificación PMP® — Tomo III",
          "author": { "@type": "Person", "name": "Valeria Yashan" },
          "url": "https://www.amazon.com/-/es/Valeria-Yashan-ebook/dp/B0H58SSYFG",
          "inLanguage": "es",
          "genre": "Project Management"
        }
      },
      {
        "@type": "ListItem",
        "position": 4,
        "item": {
          "@type": "Book",
          "name": "PM MOM",
          "author": { "@type": "Person", "name": "Valeria Yashan" },
          "url": "https://www.amazon.com/gp/product/B0H34V2L3S",
          "inLanguage": "es",
          "genre": "Leadership"
        }
      }
    ]
  }}
>

  <section class="hero">
    <h1>Mis libros</h1>
    <p class="bajada">Recursos para project managers que quieren certificarse, liderar mejor e incorporar IA a su trabajo.</p>
  </section>

  <section class="seccion">
    <p class="seccion-label">LIBROS PUBLICADOS</p>
    <h2>Guías de preparación para la certificación PMP®</h2>
    <p class="seccion-descripcion">Tres tomos diseñados para que llegues al examen con dominio real del contenido, no solo con memorización. Disponibles en Amazon en formato impreso y Kindle.</p>

    <div class="grid-libros">

      <div class="card-libro">
        <div class="cover-wrapper">
          <img src="/images/cover-tomo-1.webp" alt="Tomo I — Fundamentos y Dominios de Desempeño" class="cover" loading="lazy" />
        </div>
        <div class="card-info">
          <p class="card-label">TOMO I · FUNDAMENTOS</p>
          <h3>Dirección de Proyectos: Guía de Preparación para la Certificación</h3>
          <p>Fundamentos, marcos de trabajo y dominios de desempeño. La base conceptual para entender el nuevo enfoque del examen PMP®.</p>
          <div class="tags">
            <span class="tag">PMBOK® 8</span>
            <span class="tag">Fundamentos</span>
            <span class="tag">Español</span>
          </div>
          <div class="card-botones">
            <a href="https://www.amazon.com/-/es/Valeria-Yashan-ebook/dp/B0H4J29PP5/" target="_blank" rel="noopener" class="btn-amazon">Ver en Amazon ↗</a>
            <button class="btn-secundario" data-panel="tomo1">Material complementario ▼</button>
          </div>
          <div id="tomo1" class="material-panel" hidden>
            <p class="panel-label">Capítulos disponibles</p>
            <div class="cap-lista">
              <a href="/pmp/c1" class="cap-link">Capítulo 1 <span>→</span></a>
              <a href="/pmp/c2" class="cap-link">Capítulo 2 <span>→</span></a>
              <a href="/pmp/c3" class="cap-link">Capítulo 3 <span>→</span></a>
              <a href="/pmp/c4" class="cap-link">Capítulo 4 <span>→</span></a>
              <a href="/pmp/c5" class="cap-link">Capítulo 5 <span>→</span></a>
              <a href="/pmp/c6" class="cap-link">Capítulo 6 <span>→</span></a>
              <a href="/pmp/c7" class="cap-link">Capítulo 7 <span>→</span></a>
              <a href="/pmp/c8" class="cap-link">Capítulo 8 <span>→</span></a>
              <a href="/pmp/c9" class="cap-link">Capítulo 9 <span>→</span></a>
              <a href="/pmp/c10" class="cap-link">Capítulo 10 <span>→</span></a>
              <a href="/pmp/c11" class="cap-link">Capítulo 11 <span>→</span></a>
              <a href="/pmp/c12" class="cap-link">Capítulo 12 <span>→</span></a>
            </div>
          </div>
        </div>
      </div>

      <div class="card-libro">
        <div class="cover-wrapper">
          <img src="/images/cover-tomo-2.webp" alt="Tomo II — Procesos, Predictivo, Ágil e Híbrido" class="cover" loading="lazy" />
        </div>
        <div class="card-info">
          <p class="card-label">TOMO II · PROCESOS</p>
          <h3>Dirección de Proyectos: Procesos, Predictivo, Ágil e Híbrido</h3>
          <p>Los enfoques de entrega explicados con criterio profesional y ejemplos reales. Cuándo elegir cada uno y cómo combinarlos en proyectos híbridos.</p>
          <div class="tags">
            <span class="tag">ECO</span>
            <span class="tag">Predictivo</span>
            <span class="tag">Ágil</span>
          </div>
          <div class="card-botones">
            <a href="https://www.amazon.com/-/es/dp/B0H5DWJ5VM" target="_blank" rel="noopener" class="btn-amazon">Ver en Amazon ↗</a>
            <button class="btn-secundario" data-panel="tomo2">Material complementario ▼</button>
          </div>
          <div id="tomo2" class="material-panel" hidden>
            <p class="panel-label">Capítulos disponibles</p>
            <div class="cap-lista">
              <a href="/pmp/c13" class="cap-link">Capítulo 13 <span>→</span></a>
              <a href="/pmp/c14" class="cap-link">Capítulo 14 <span>→</span></a>
              <a href="/pmp/c15" class="cap-link">Capítulo 15 <span>→</span></a>
              <a href="/pmp/c16" class="cap-link">Capítulo 16 <span>→</span></a>
              <a href="/pmp/c17" class="cap-link">Capítulo 17 <span>→</span></a>
              <a href="/pmp/c18" class="cap-link">Capítulo 18 <span>→</span></a>
              <a href="/pmp/c19" class="cap-link">Capítulo 19 <span>→</span></a>
              <a href="/pmp/c20" class="cap-link">Capítulo 20 <span>→</span></a>
            </div>
          </div>
        </div>
      </div>

      <div class="card-libro">
        <div class="cover-wrapper">
          <img src="/images/cover-tomo-3.webp" alt="Tomo III — Práctica y Simulacros PMP" class="cover" loading="lazy" />
        </div>
        <div class="card-info">
          <p class="card-label">TOMO III · PRÁCTICA</p>
          <h3>Dirección de Proyectos: Práctica y Simulacros para la Certificación</h3>
          <p>180 preguntas con distribución ECO real, justificación detallada de cada respuesta y diagnóstico de brechas para el repaso final antes del examen.</p>
          <div class="tags">
            <span class="tag">PMBOK® 8</span>
            <span class="tag">180 preguntas</span>
            <span class="tag">Español</span>
          </div>
          <div class="card-botones">
            <a href="https://www.amazon.com/-/es/Valeria-Yashan-ebook/dp/B0H58SSYFG" target="_blank" rel="noopener" class="btn-amazon">Ver en Amazon ↗</a>
            <a href="/simulador" class="btn-secundario">Simulador de práctica ↗</a>
          </div>
        </div>
      </div>

    </div>

    <div class="serie-completa">
      <p>¿Querés los tres tomos juntos?</p>
      <a href="https://www.amazon.com/-/es/dp/B0H4JF5FNH?binding=kindle_edition&ref_=saga_dp_bnx_dsk_sdp" target="_blank" rel="noopener" class="btn-amazon">Ver serie completa en Amazon ↗</a>
    </div>

    <div class="libro-cta">
      <p class="libro-cta-eyebrow">¿Tenés los libros y querés ir más lejos?</p>
      <h2 class="libro-cta-titulo">Preparate para el PMP® con acompañamiento real</h2>
      <p class="libro-cta-texto">Si querés llegar al examen con comprensión real del contenido y no solo con memorización, puedo acompañarte en el proceso.</p>
      <a href="/servicios/certificacion-pmp" class="btn-primary">Ver servicio de preparación PMP® →</a>
    </div>

  </section>

  <hr class="separador" />

  <section class="seccion">
    <h2>PM MOM</h2>
    <p class="seccion-descripcion">Un libro diferente. Para las project managers que también son madres, y para quienes quieren entender cómo se lidera un proyecto cuando la vida personal también exige gestión.</p>

    <div class="card-libro card-libro--horizontal">
      <div class="cover-wrapper-horizontal">
        <img src="/images/cover-pm-mom.webp" alt="PM MOM — Valeria Yashan" class="cover-horizontal" loading="lazy" />
      </div>
      <div class="card-info">
        <p class="card-label">LIBRO · LIDERAZGO PERSONAL</p>
        <h3>PM MOM</h3>
        <p>Una mirada honesta sobre maternidad, liderazgo y gestión de proyectos. Porque los proyectos más importantes no siempre están en el trabajo.</p>
        <div class="tags">
          <span class="tag">Liderazgo</span>
          <span class="tag">Maternidad</span>
          <span class="tag">Español</span>
        </div>
        <div class="card-botones">
          <a href="https://www.amazon.com/gp/product/B0H34V2L3S" target="_blank" rel="noopener" class="btn-amazon">Ver en Amazon ↗</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.btn-secundario').forEach((btn) => {
      btn.addEventListener('click', () => {
        const id = btn.dataset.panel;
        const panel = document.getElementById(id);
        const abierto = !panel.hidden;
        panel.hidden = abierto;
        btn.textContent = abierto
          ? 'Material complementario \u25BC'
          : 'Material complementario \u25B2';
      });
    });
  });
</script>

<style>
  .hero {
    text-align: center;
    padding: 3rem 1rem 2rem;
    max-width: 700px;
    margin: 0 auto;
  }

  .hero h1 {
    font-family: 'Fraunces', serif;
    font-size: 2.5rem;
    font-weight: 900;
    color: var(--color-text);
    margin-bottom: 1rem;
  }

  .bajada {
    font-size: 1.1rem;
    color: var(--color-muted);
    line-height: 1.6;
  }

  .seccion {
    max-width: 900px;
    margin: 0 auto;
    padding: 3rem 1rem;
  }

  .seccion-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .seccion h2 {
    font-family: 'Fraunces', serif;
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }

  .seccion-descripcion {
    color: var(--color-muted);
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 650px;
  }

  .separador {
    border: none;
    border-top: 1px solid var(--color-border);
    max-width: 900px;
    margin: 0 auto;
  }

  .grid-libros {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .card-libro {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .cover-wrapper {
    background: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    height: 240px;
    border-bottom: 1px solid var(--color-border);
  }

  .cover {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
  }

  .card-info {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  .card-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    text-transform: uppercase;
    margin: 0;
  }

  .card-info h3 {
    font-family: 'Fraunces', serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
    line-height: 1.4;
  }

  .card-info p {
    color: var(--color-muted);
    font-size: 0.875rem;
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    font-family: 'Inter', sans-serif;
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--color-muted);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 0.2rem 0.5rem;
  }

  .card-botones {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
    margin-top: auto;
  }

  .btn-amazon {
    display: inline-flex;
    align-items: center;
    background: #FF9900;
    color: #fff;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 0.875rem;
    padding: 0.55rem 1.1rem;
    border-radius: 6px;
    text-decoration: none;
    transition: opacity 0.2s;
    min-height: 40px;
    white-space: nowrap;
    border: none;
    cursor: pointer;
  }

  .btn-amazon:hover { opacity: 0.88; }

  .btn-secundario {
    display: inline-flex;
    align-items: center;
    background: transparent;
    color: var(--color-accent);
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 0.875rem;
    padding: 0.55rem 1.1rem;
    border-radius: 6px;
    border: 1px solid var(--color-accent);
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    min-height: 40px;
    white-space: nowrap;
  }

  .btn-secundario:hover {
    background: var(--color-accent);
    color: #fff;
  }

  .material-panel {
    border-top: 1px solid var(--color-border);
    padding-top: 0.75rem;
    margin-top: 0.25rem;
  }

  .panel-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin: 0 0 0.5rem;
  }

  .cap-lista {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .cap-link {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    padding: 0.45rem 0.75rem;
    border-radius: 6px;
    background: var(--color-bg);
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: background 0.15s;
  }

  .cap-link:hover { background: var(--color-border); }

  .cap-link span {
    color: var(--color-accent);
    font-size: 0.9rem;
  }

  .card-libro--horizontal {
    flex-direction: row;
    max-width: 620px;
  }

  .cover-wrapper-horizontal {
    background: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem 1.25rem;
    border-right: 1px solid var(--color-border);
    flex-shrink: 0;
  }

  .cover-horizontal {
    width: 160px;
    height: auto;
    object-fit: contain;
    display: block;
  }

  .serie-completa {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .serie-completa p {
    color: var(--color-muted);
    margin: 0;
    font-size: 0.95rem;
  }

  .libro-cta {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-accent);
    border-radius: 0 8px 8px 0;
    padding: 1.75rem 2rem;
    margin-top: 2rem;
  }

  .libro-cta-eyebrow {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: 0.4rem;
  }

  .libro-cta-titulo {
    font-family: 'Fraunces', serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .libro-cta-texto {
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.65;
    margin-bottom: 1.25rem;
    max-width: 560px;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    background: var(--color-accent);
    color: #fff;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    padding: 0.75rem 1.5rem;
    border-radius: 6px;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .btn-primary:hover { opacity: 0.88; }

  @media (max-width: 700px) {
    .hero h1 { font-size: 1.8rem; }
    .grid-libros { grid-template-columns: 1fr; }
    .cover-wrapper { height: 220px; }
    .card-libro--horizontal { flex-direction: column; }
    .cover-wrapper-horizontal { border-right: none; border-bottom: 1px solid var(--color-border); }
    .cover-horizontal { width: 130px; }
    .card-botones { flex-direction: column; align-items: flex-start; }
    .btn-amazon, .btn-secundario { width: 100%; justify-content: center; }
    .libro-cta { padding: 1.25rem; }
  }
</style>