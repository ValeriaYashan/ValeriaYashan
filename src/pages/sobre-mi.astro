---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Sobre mí — Valeria Yashan"
  description="Valeria Yashan — Project Manager certificada (PMP®), MBA, Ingeniera Industrial. Más de 10 años liderando proyectos de transformación digital en energía, finanzas y tecnología."
>
  <div class="container page-container">

    <!-- HERO CON FOTO -->
    <section class="sobre-hero">
      <div class="sobre-foto-wrap">
        <img src="/images/valeria-yashan.jpg" alt="Valeria Yashan" class="sobre-foto" width="180" height="240" />
      </div>
      <div class="sobre-intro mark-accent">
        <p class="page-eyebrow">Sobre mí</p>
        <h1>Valeria Yashan</h1>
        <p class="hero-tags">PMP® · MBA · Ingeniera Industrial · Autora · Docente</p>
        <p class="sobre-bio">Project Manager con más de 10 años liderando proyectos de transformación digital en energía, finanzas y tecnología. Combino metodologías probadas de gestión de proyectos con herramientas de inteligencia artificial aplicada.</p>
        <p class="sobre-bio">También escribo y enseño: publiqué libros sobre gestión de proyectos y certificación PMP®, doy clases universitarias y capacito equipos profesionales.</p>
        <div class="hero-actions">
          <a href="/contacto" class="btn btn-primary">Contacto →</a>
          <a href="https://www.linkedin.com/in/valeriayashan/" target="_blank" rel="noopener noreferrer" class="btn btn-outline">LinkedIn →</a>
        </div>
      </div>
    </section>

    <!-- DOS COLUMNAS: FORMACIÓN + PUBLICACIONES -->
    <section class="sobre-seccion">
      <div class="dos-columnas">

        <div class="columna">
          <h2>Formación y certificaciones</h2>
          <div class="creds-grid">
            <div class="cred-item">
              <span class="cred-icon">→</span>
              <div>
                <p class="cred-titulo">PMP® — Project Management Professional</p>
                <p class="cred-detalle">PMI #1613335 · Vigente desde 2013</p>
              </div>
            </div>
            <div class="cred-item">
              <span class="cred-icon">→</span>
              <div>
                <p class="cred-titulo">MBA</p>
                <p class="cred-detalle">Universidad del CEMA · 2025</p>
              </div>
            </div>
            <div class="cred-item">
              <span class="cred-icon">→</span>
              <div>
                <p class="cred-titulo">Ingeniería Industrial</p>
                <p class="cred-detalle">Universidad Nacional de La Plata · 2008</p>
              </div>
            </div>
            <div class="cred-item">
              <span class="cred-icon">→</span>
              <div>
                <p class="cred-titulo">Especialización en Gestión de Proyectos</p>
                <p class="cred-detalle">UTN · 2009</p>
              </div>
            </div>
            <div class="cred-item">
              <span class="cred-icon">→</span>
              <div>
                <p class="cred-titulo">Certificación Avanzada en Metodologías Ágiles</p>
                <p class="cred-detalle">2021</p>
              </div>
            </div>
            <div class="cred-item">
              <span class="cred-icon">→</span>
              <div>
                <p class="cred-titulo">Profesorado Universitario</p>
                <p class="cred-detalle">Universidad de San Andrés UDESA · 2018</p>
              </div>
            </div>
          </div>
        </div>

        <div class="columna">
          <h2>Publicaciones</h2>
          <div class="creds-grid">
            <div class="cred-item">
              <span class="cred-icon">→</span>
              <div>
                <p class="cred-titulo">PM MOM</p>
                <p class="cred-detalle">Gestión de proyectos aplicada a la maternidad</p>
              </div>
            </div>
            <div class="cred-item">
              <span class="cred-icon">→</span>
              <div>
                <p class="cred-titulo">Dirección de Proyectos — Tomo I</p>
                <p class="cred-detalle">Fundamentos, Gestión de Personas y Planificación</p>
              </div>
            </div>
            <div class="cred-item">
              <span class="cred-icon">→</span>
              <div>
                <p class="cred-titulo">Dirección de Proyectos — Tomo III</p>
                <p class="cred-detalle">Simulacros PMP® · PMBOK® 8 · ECO julio 2026</p>
              </div>
            </div>
          </div>
          <a href="/libro" class="link-libros">Ver todos los libros →</a>

          <h2 style="margin-top: 1.25rem;">Blog</h2>
          <div class="creds-grid">
            <div class="cred-item">
              <span class="cred-icon">→</span>
              <div>
                <p class="cred-titulo">Project Management e IA aplicada</p>
                <p class="cred-detalle">Artículos sobre PM, certificación PMP® e inteligencia artificial</p>
              </div>
            </div>
          </div>
          <a href="/blog" class="link-libros">Leer artículos →</a>
        </div>

      </div>
    </section>

  </div>
</BaseLayout>

<style>
  .page-container {
    padding-top: 1.75rem;
    padding-bottom: 2rem;
  }

  .sobre-hero {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 2rem;
    align-items: start;
    margin-bottom: 1.25rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--color-border);
  }

  .sobre-foto-wrap {
    width: 180px;
  }

  .sobre-foto {
    width: 180px;
    height: 240px;
    border-radius: var(--radius);
    display: block;
    object-fit: cover;
    object-position: top center;
  }

  .sobre-intro {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .page-eyebrow {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin: 0;
  }

  .sobre-intro h1 {
    margin: 0;
    font-size: 2rem;
    line-height: 1.1;
  }

  .hero-tags {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    margin: 0;
  }

  .sobre-bio {
    color: var(--color-muted);
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.55;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 0.2rem;
  }

  .sobre-seccion {
    margin-bottom: 0;
  }

  .dos-columnas {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  .columna h2 {
    font-size: 0.72rem;
    font-family: var(--font-body);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-muted);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.35rem;
    margin-bottom: 0.4rem;
    margin-top: 0;
  }

  .creds-grid {
    display: flex;
    flex-direction: column;
  }

  .cred-item {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 0.38rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .cred-item:last-child {
    border-bottom: none;
  }

  .cred-icon {
    color: var(--color-accent);
    font-weight: 700;
    flex-shrink: 0;
    font-size: 0.8rem;
    margin-top: 0.15rem;
  }

  .cred-titulo {
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 0.05rem 0;
    font-size: 0.85rem;
  }

  .cred-detalle {
    color: var(--color-muted);
    font-size: 0.76rem;
    margin: 0;
  }

  .link-libros {
    display: inline-block;
    margin-top: 0.5rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-accent);
  }

  @media (max-width: 680px) {
    .sobre-hero {
      grid-template-columns: 1fr;
    }

    .sobre-foto {
      width: 130px;
      height: 173px;
    }

    .dos-columnas {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>