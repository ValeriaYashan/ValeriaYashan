---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contacto"
  description="Contacto profesional de Valeria Yashan — PM, consultora en IA y autora."
>
  <div class="container page-container">
    <header class="page-header mark-accent">
      <p class="page-eyebrow">Contacto</p>
      <h1>Hablemos</h1>
      <p class="page-lead">
        Para consultas profesionales, colaboraciones, charlas o cualquier pregunta
        sobre el libro, podés escribirme por LinkedIn o por mail.
      </p>
    </header>

    <section class="contact-options">
      <div class="contact-card">
        <p class="contact-label">LinkedIn</p>
        <p class="contact-desc">La forma más rápida de contactarme para consultas profesionales.</p>
        <a href="https://www.linkedin.com/in/valeriayashan" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Ir a LinkedIn →</a>
      </div>

      <div class="contact-card">
        <p class="contact-label">Email</p>
        <p class="contact-desc">Para consultas formales o propuestas de colaboración.</p>
        <a href="mailto:hola@valeriayashan.com.ar" class="btn btn-outline">hola@valeriayashan.com.ar</a>
      </div>
    </section>

    <section class="contact-note">
      <p>También podés encontrarme en <a href="/blog">el blog</a> o acceder al <a href="/libro">material del libro</a>.</p>
    </section>
  </div>
</BaseLayout>

<style>
  .page-container {
    padding-top: var(--space-lg);
    padding-bottom: var(--space-xl);
  }

  .page-header {
    margin-bottom: var(--space-lg);
  }

  .page-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  .page-lead {
    font-size: 1.1rem;
    color: var(--color-muted);
    margin-top: var(--space-sm);
    margin-bottom: 0;
    max-width: 520px;
  }

  .contact-options {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .contact-card {
    background: var(--color-surface);
    padding: var(--space-md);
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
  }

  .contact-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  .contact-desc {
    color: var(--color-muted);
    font-size: 0.9rem;
    margin-bottom: var(--space-sm);
  }

  .contact-note {
    color: var(--color-muted);
    font-size: 0.9rem;
  }

  @media (max-width: 600px) {
    .contact-options {
      grid-template-columns: 1fr;
    }
  }
</style>