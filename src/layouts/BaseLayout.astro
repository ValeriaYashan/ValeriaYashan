---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title = 'Mis libros — Valeria Yashan',
  description = 'Trilogía PMP® y PM MOM: todos los libros de Valeria Yashan disponibles en Amazon. Project Management en español, alineados con PMBOK® Guide Eighth Edition.',
  image = '/images/og-default.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const fullTitle = title.includes('Valeria Yashan') ? title : `${title} — Valeria Yashan`;
const imageURL = new URL(image, Astro.site);
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageURL} />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:site_name" content="Valeria Yashan" />

    <!-- Twitter/X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-DK70Z7NVB9"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-DK70Z7NVB9');
    </script>
  </head>
  <body>
    <Header />
    <main>

      <!-- HERO -->
      <section class="libros-hero">
        <h1>Mis libros</h1>
        <p class="libros-intro">
          Escribí estos libros para que puedas aplicar Project Management de forma concreta,
          ya sea preparándote para la certificación PMP® o incorporando estas herramientas
          a tu vida cotidiana y profesional.
        </p>
      </section>

      <!-- PM MOM -->
      <section class="libros-seccion">
        <article class="libro-card libro-card--destacado">
          <div class="libro-cover">
            <img
              src="/images/cover-pm-mom.jpg"
              alt="Portada del libro PM MOM de Valeria Yashan"
              width="200"
              height="300"
              loading="lazy"
              onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
            />
            <div class="cover-fallback" style="display:none;"><span>PM MOM</span></div>
          </div>
          <div class="libro-info">
            <span class="libro-tag">Project Management · Parentalidad</span>
            <h2>PM MOM</h2>
            <p class="libro-descripcion">
              Una guía práctica para madres (y padres) que quieren aplicar los principios
              del Project Management a la crianza y la organización familiar.
              Porque gestionar una familia también es gestionar un proyecto.
            </p>
            <div class="libro-acciones">
              <a href="https://www.amazon.com/-/es/Valeria-Yashan-ebook/dp/B0H4J29PP5/" target="_blank" rel="noopener noreferrer" class="btn-amazon">Comprar en Amazon</a>
            </div>
          </div>
        </article>
      </section>

      <!-- TRILOGÍA -->
      <section class="serie-header">
        <div class="serie-badge">Serie completa · 3 volúmenes</div>
        <h2 class="serie-titulo">Dirección de Proyectos: Guía de Preparación para la Certificación</h2>
        <p class="serie-subtitulo">Valeria Yashan, PMP® · Directora de Proyectos · Docente universitaria</p>
        <a href="https://www.amazon.com/-/es/dp/B0H5DWJ5VM?ref_=saga_dp_bnx_dsk_dp" target="_blank" rel="noopener noreferrer" class="btn-amazon btn-serie">Comprar los 3 tomos en Amazon</a>
      </section>

      <section class="libros-grid">

        <!-- TOMO I -->
        <article class="libro-card">
          <div class="libro-cover">
            <div class="tomo-badge">Tomo I</div>
            <img
              src="/images/cover-tomo-1.jpg"
              alt="Portada Tomo I — Fundamentos, Gestión de Personas y Planificación de Procesos"
              width="200"
              height="300"
              loading="lazy"
              onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
            />
            <div class="cover-fallback" style="display:none;"><span>Tomo I</span></div>
          </div>
          <div class="libro-info">
            <span class="libro-tag">PMP® · Fundamentos · Personas · Proceso</span>
            <h2>Tomo I — Fundamentos, Gestión de Personas y Planificación de Procesos</h2>
            <p class="libro-descripcion">
              Cubre los fundamentos del PMBOK® Guide Eighth Edition, el dominio Personas completo
              y los primeros capítulos del dominio Proceso. Incluye criterio situacional, errores
              frecuentes, caso aplicado y preguntas de práctica con explicación razonada.
              Cuatro planes de estudio de 4, 6, 8 y 12 semanas.
            </p>
            <ul class="libro-features">
              <li>582 páginas · Caps. 1–12</li>
              <li>Dominio Personas completo</li>
              <li>4 planes de estudio adaptados</li>
              <li>Preguntas con justificación detallada</li>
            </ul>
            <div class="libro-acciones">
              <a href="https://www.amazon.com/-/es/Valeria-Yashan-ebook/dp/B0H4J29PP5/" target="_blank" rel="noopener noreferrer" class="btn-amazon">Comprar en Amazon</a>
            </div>
          </div>
        </article>

        <!-- TOMO II -->
        <article class="libro-card">
          <div class="libro-cover">
            <div class="tomo-badge">Tomo II</div>
            <img
              src="/images/cover-tomo-2.jpg"
              alt="Portada Tomo II — Proceso, Entorno de Negocio y Herramientas de Entrenamiento"
              width="200"
              height="300"
              loading="lazy"
              onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
            />
            <div class="cover-fallback" style="display:none;"><span>Tomo II</span></div>
          </div>
          <div class="libro-info">
            <span class="libro-tag">PMP® · Proceso · Entorno de Negocio · Herramientas</span>
            <h2>Tomo II — Proceso, Entorno de Negocio y Herramientas de Entrenamiento</h2>
            <p class="libro-descripcion">
              Cierra el dominio Proceso con los capítulos más técnicos: valor ganado, riesgos
              y adquisiciones. Cubre el dominio Entorno de negocio completo, incluyendo IA
              en la dirección de proyectos y sostenibilidad. 175 preguntas de práctica
              con acceso a respuestas por QR.
            </p>
            <ul class="libro-features">
              <li>305 páginas · Caps. 13–21</li>
              <li>Dominio Entorno de negocio completo</li>
              <li>Glosario bilingüe español-inglés</li>
              <li>175 preguntas de práctica con QR</li>
            </ul>
            <div class="libro-acciones">
              <a href="https://www.amazon.com/-/es/dp/B0H5DWJ5VM" target="_blank" rel="noopener noreferrer" class="btn-amazon">Comprar en Amazon</a>
            </div>
          </div>
        </article>

        <!-- TOMO III -->
        <article class="libro-card">
          <div class="libro-cover">
            <div class="tomo-badge">Tomo III</div>
            <img
              src="/images/cover-tomo-3.jpg"
              alt="Portada Tomo III — Simulacros de Práctica Intensiva"
              width="200"
              height="300"
              loading="lazy"
              onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
            />
            <div class="cover-fallback" style="display:none;"><span>Tomo III</span></div>
          </div>
          <div class="libro-info">
            <span class="libro-tag">PMP® · Simulacros · Práctica Intensiva</span>
            <h2>Tomo III — Simulacros de Práctica Intensiva</h2>
            <p class="libro-descripcion">
              180 preguntas de simulacro para el examen de certificación. Diseñado para quienes
              ya completaron los Tomos I y II y necesitan entrenar bajo condiciones reales.
              Simulacros por dominio ECO, simulacro final integrado y casos de alta complejidad
              con subpreguntas encadenadas.
            </p>
            <ul class="libro-features">
              <li>170 páginas · Caps. 22–23</li>
              <li>60 preguntas por dominio ECO</li>
              <li>120 preguntas de simulacro final</li>
              <li>Respuestas con justificación detallada</li>
            </ul>
            <div class="libro-acciones">
              <a href="https://www.amazon.com/-/es/Valeria-Yashan-ebook/dp/B0H58SSYFG" target="_blank" rel="noopener noreferrer" class="btn-amazon">Comprar en Amazon</a>
            </div>
          </div>
        </article>

      </section>

      <!-- RECURSOS -->
      <section class="libros-recursos">
        <h2>Material complementario</h2>
        <p>Recursos adicionales para acompañar tu estudio: glosarios, plantillas y guías descargables.</p>
        <a href="/recursos" class="btn-secundario">Ver recursos descargables</a>
      </section>

    </main>
    <Footer />
  </body>
</html>

<style>
  .libros-hero {
    max-width: 720px;
    margin: 0 auto 3.5rem;
    text-align: center;
    padding: 3rem 1.5rem 0;
  }
  .libros-hero h1 {
    font-family: 'Fraunces', serif;
    font-size: 2.5rem;
    font-weight: 900;
    color: var(--color-text);
    margin-bottom: 1rem;
  }
  .libros-intro {
    font-size: 1.05rem;
    color: var(--color-muted);
    line-height: 1.7;
    max-width: 620px;
    margin: 0 auto;
  }

  /* PM MOM — sección separada */
  .libros-seccion {
    max-width: 900px;
    margin: 0 auto 4rem;
    padding: 0 1.5rem;
  }
  .libro-card--destacado {
    border-left: 4px solid var(--color-accent);
  }

  /* SERIE HEADER */
  .serie-header {
    max-width: 900px;
    margin: 0 auto 2.5rem;
    padding: 2rem 1.5rem;
    background: var(--color-accent);
    border-radius: 12px;
    text-align: center;
    color: #fff;
  }
  .serie-badge {
    display: inline-block;
    background: rgba(255,255,255,0.2);
    color: #fff;
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    margin-bottom: 0.75rem;
  }
  .serie-titulo {
    font-family: 'Fraunces', serif;
    font-size: 1.4rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 0.4rem;
    line-height: 1.3;
  }
  .serie-subtitulo {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.8);
    margin-bottom: 1.25rem;
  }
  .btn-serie {
    font-size: 0.95rem;
    padding: 0.75rem 1.75rem;
  }

  /* GRID */
  .libros-grid {
    max-width: 900px;
    margin: 0 auto 5rem;
    padding: 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }
  .libro-card {
    display: flex;
    gap: 2.5rem;
    align-items: flex-start;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 2rem;
  }

  /* PORTADA */
  .libro-cover {
    flex-shrink: 0;
    position: relative;
  }
  .libro-cover img {
    width: 160px;
    height: auto;
    border-radius: 6px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.15);
    display: block;
  }
  .cover-fallback {
    width: 160px;
    height: 220px;
    background: var(--color-accent);
    border-radius: 6px;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-family: 'Fraunces', serif;
    font-size: 1.1rem;
    font-weight: 700;
    text-align: center;
    padding: 1rem;
  }
  .tomo-badge {
    position: absolute;
    top: -10px;
    left: -10px;
    background: var(--color-accent);
    color: #fff;
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    z-index: 1;
  }

  /* INFO */
  .libro-info {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .libro-tag {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-family: 'Inter', sans-serif;
  }
  .libro-info h2 {
    font-family: 'Fraunces', serif;
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
  }
  .libro-descripcion {
    color: var(--color-muted);
    font-size: 0.92rem;
    line-height: 1.7;
    margin: 0;
  }
  .libro-features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .libro-features li {
    font-size: 0.85rem;
    color: var(--color-muted);
    font-family: 'Inter', sans-serif;
    padding-left: 1.2em;
    position: relative;
  }
  .libro-features li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: 700;
  }
  .libro-acciones {
    margin-top: 0.5rem;
  }

  /* BOTONES */
  .btn-amazon {
    display: inline-block;
    background: #FF9900;
    color: #FFFFFF;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    padding: 0.65rem 1.4rem;
    border-radius: 6px;
    text-decoration: none;
    transition: background 0.2s ease;
  }
  .btn-amazon:hover { background: #e68a00; }

  .btn-secundario {
    display: inline-block;
    background: var(--color-accent);
    color: #FFFFFF;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    padding: 0.65rem 1.4rem;
    border-radius: 6px;
    text-decoration: none;
    transition: background 0.2s ease;
  }
  .btn-secundario:hover { background: #1B4332; }

  /* RECURSOS */
  .libros-recursos {
    max-width: 900px;
    margin: 0 auto 5rem;
    padding: 2.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    text-align: center;
  }
  .libros-recursos h2 {
    font-family: 'Fraunces', serif;
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }
  .libros-recursos p {
    color: var(--color-muted);
    margin-bottom: 1.5rem;
    line-height: 1.6;
    font-size: 0.95rem;
  }

  /* MOBILE */
  @media (max-width: 640px) {
    .libro-card {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .libro-cover img,
    .cover-fallback { width: 140px; }
    .libro-features li { text-align: left; }
    .libros-hero h1 { font-size: 2rem; }
    .serie-titulo { font-size: 1.2rem; }
    .tomo-badge {
      top: -8px;
      left: 50%;
      transform: translateX(-50%);
    }
  }
</style>