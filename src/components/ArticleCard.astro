---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  category: string;
  slug: string;
  readingTime?: number;
  tags?: string[];
  image?: string;
}

const { title, description, pubDate, category, slug, readingTime = 5, tags = [], image } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('es-AR', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
}).toUpperCase();
---

<article class="article-card">
  <a href={`/blog/${slug}`} class="card-link">

    {image && (
      <div class="card-imagen-wrap">
        <img
          src={image}
          alt={title}
          class="card-imagen"
          width="800"
          height="420"
          loading="lazy"
        />
      </div>
    )}

    {!image && (
      <div class="card-imagen-placeholder">
        <span class="card-imagen-category">{category}</span>
      </div>
    )}

    <div class="card-body">
      <div class="card-meta">
        <span class="card-category">{category}</span>
        <span class="card-reading">{readingTime} min</span>
      </div>

      {tags.length > 0 && (
        <div class="card-tags">
          {tags.map(tag => (
            <span class="card-tag">{tag}</span>
          ))}
        </div>
      )}

      <h2 class="card-title">{title}</h2>
      <p class="card-description">{description}</p>
      <div class="card-footer">
        <time datetime={pubDate.toISOString()} class="card-date">{formattedDate}</time>
        <span class="card-cta">Leer →</span>
      </div>
    </div>

  </a>
</article>

<style>
  .article-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.15s ease;
  }

  .article-card:hover {
    border-color: var(--color-accent);
  }

  .card-link {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  .card-imagen-wrap {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .card-imagen {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.3s ease;
  }

  .article-card:hover .card-imagen {
    transform: scale(1.03);
  }

  .card-imagen-placeholder {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-imagen-category {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255,255,255,0.7);
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.25rem 1.5rem 1.5rem;
    flex: 1;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .card-category {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    background: var(--color-surface);
    padding: 3px 10px;
    border-radius: 20px;
  }

  .card-reading {
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .card-tag {
    font-size: 0.68rem;
    font-weight: 500;
    color: var(--color-muted);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 2px 8px;
    border-radius: 20px;
    letter-spacing: 0.02em;
  }

  .card-title {
    font-family: 'Fraunces', serif;
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.35;
    margin: 0;
    transition: color 0.15s ease;
  }

  .card-link:hover .card-title {
    color: var(--color-accent);
  }

  .card-description {
    color: var(--color-muted);
    font-size: 0.875rem;
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
  }

  .card-date {
    font-size: 0.78rem;
    color: var(--color-muted);
    font-weight: 500;
    letter-spacing: 0.03em;
  }

  .card-cta {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
  }
</style>