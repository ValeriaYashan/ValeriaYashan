---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  category: string;
  slug: string;
  readingTime?: number;
}

const { title, description, pubDate, category, slug, readingTime = 5 } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('es-AR', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
}).toUpperCase();
---

<article class="article-card">
  <a href={`/blog/${slug}`} class="card-link">
    <div class="card-meta">
      <span class="card-category">{category}</span>
      <span class="card-reading">{readingTime} min</span>
    </div>
    <h2 class="card-title">{title}</h2>
    <p class="card-description">{description}</p>
    <div class="card-footer">
      <time datetime={pubDate.toISOString()} class="card-date">{formattedDate}</time>
      <span class="card-cta">Leer →</span>
    </div>
  </a>
</article>

<style>
  .article-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem;
    transition: border-color 0.15s ease;
  }

  .article-card:hover {
    border-color: var(--color-accent);
  }

  .card-link {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .card-category {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    background: var(--color-surface);
    padding: 3px 10px;
    border-radius: 20px;
  }

  .card-reading {
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  .card-title {
    font-family: 'Fraunces', serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.35;
    margin: 0;
    transition: color 0.15s ease;
  }

  .card-link:hover .card-title {
    color: var(--color-accent);
  }

  .card-description {
    color: var(--color-muted);
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
  }

  .card-date {
    font-size: 0.78rem;
    color: var(--color-muted);
    font-weight: 500;
    letter-spacing: 0.03em;
  }

  .card-cta {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
  }
</style>