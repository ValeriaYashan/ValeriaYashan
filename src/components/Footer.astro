---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container--wide footer-inner">
    <p class="footer-name">Valeria Yashan</p>
    <div class="footer-links">
      <a href="https://www.linkedin.com/in/valeriayashan" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <span class="footer-sep">·</span>
      <a href="/libro">Libro</a>
      <span class="footer-sep">·</span>
      <a href="/recursos">Recursos</a>
      <span class="footer-sep">·</span>
      <a href="/contacto">Contacto</a>
    </div>
    <p class="footer-copy">© {year} Valeria Yashan. Todos los derechos reservados.</p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-xl);
    border-top: 1px solid var(--color-border);
    padding: var(--space-md) 0;
    background-color: var(--color-bg);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
  }

  .footer-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1rem;
    margin-bottom: 0;
  }

  .footer-links {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
  }

  .footer-links a {
    color: var(--color-muted);
    text-decoration: none;
  }

  .footer-links a:hover {
    color: var(--color-accent);
  }

  .footer-sep {
    color: var(--color-border);
  }

  .footer-copy {
    font-size: 0.8rem;
    color: var(--color-muted);
    margin-bottom: 0;
  }
</style>