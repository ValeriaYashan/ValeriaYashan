---
<div class="mapa-wrap">

  <div class="mapa-legend">
    <span class="leg-item leg-gen">&#9679; IA generativa</span>
    <span class="leg-item leg-auto">&#9679; Automatizaci&#243;n</span>
    <span class="leg-item leg-pres">&#9679; Presentaciones</span>
    <span class="leg-item leg-anal">&#9679; Anal&#237;tica</span>
    <span class="leg-item leg-doc">&#9679; An&#225;lisis de docs</span>
  </div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Rubro / perfil</th>
          <th>Herramientas</th>
          <th class="col-caso">Caso de uso ancla</th>
          <th>Prioridad</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><strong>Ventas y comercial</strong><br/><span class="rubro-sub">Ejecutivos, asesores, KAM</span></td>
          <td><div class="pills"><span class="pill pill-gen">ChatGPT / Claude</span><span class="pill pill-auto">Make / Zapier</span><span class="pill pill-pres">Gamma</span></div></td>
          <td class="col-caso">Redactar propuestas en minutos y automatizar seguimiento de leads</td>
          <td><span class="pri pri-high">Alta</span></td>
        </tr>
        <tr>
          <td><strong>Marketing y contenidos</strong><br/><span class="rubro-sub">Agencias, coordinadores, brand managers</span></td>
          <td><div class="pills"><span class="pill pill-gen">ChatGPT / Claude</span><span class="pill pill-pres">Gamma</span><span class="pill pill-anal">Perplexity</span></div></td>
          <td class="col-caso">Generar copies y reportes de campa&#241;a sin bloqueo creativo</td>
          <td><span class="pri pri-high">Alta</span></td>
        </tr>
        <tr>
          <td><strong>Consultor&#237;a y estrategia</strong><br/><span class="rubro-sub">Consultores, directores, asesores</span></td>
          <td><div class="pills"><span class="pill pill-gen">ChatGPT / Claude</span><span class="pill pill-doc">NotebookLM</span><span class="pill pill-anal">Perplexity</span><span class="pill pill-pres">Gamma</span></div></td>
          <td class="col-caso">Analizar informes y armar entregables ejecutivos r&#225;pido</td>
          <td><span class="pri pri-high">Alta</span></td>
        </tr>
        <tr>
          <td><strong>Gesti&#243;n de proyectos</strong><br/><span class="rubro-sub">PMs, l&#237;deres de equipo, PMO</span></td>
          <td><div class="pills"><span class="pill pill-gen">ChatGPT / Claude</span><span class="pill pill-auto">Make / Zapier</span><span class="pill pill-doc">NotebookLM</span></div></td>
          <td class="col-caso">Generar reportes de avance y automatizar actualizaciones a stakeholders</td>
          <td><span class="pri pri-high">Alta</span></td>
        </tr>
        <tr>
          <td><strong>Abogados y estudios jur&#237;dicos</strong><br/><span class="rubro-sub">Abogados, asistentes legales</span></td>
          <td><div class="pills"><span class="pill pill-doc">NotebookLM</span><span class="pill pill-gen">ChatGPT / Claude</span></div></td>
          <td class="col-caso">Resumir contratos e identificar cl&#225;usulas cr&#237;ticas en minutos</td>
          <td><span class="pri pri-high">Alta</span></td>
        </tr>
        <tr>
          <td><strong>Contadores y finanzas</strong><br/><span class="rubro-sub">Contadores, CFOs, analistas</span></td>
          <td><div class="pills"><span class="pill pill-gen">ChatGPT / Claude</span><span class="pill pill-anal">Copilot / Gemini</span><span class="pill pill-auto">Make / Zapier</span></div></td>
          <td class="col-caso">Automatizar informes peri&#243;dicos y analizar datos con lenguaje natural</td>
          <td><span class="pri pri-medh">Media-Alta</span></td>
        </tr>
        <tr>
          <td><strong>RRHH y gesti&#243;n de personas</strong><br/><span class="rubro-sub">HR managers, gerentes de &#225;rea</span></td>
          <td><div class="pills"><span class="pill pill-gen">ChatGPT / Claude</span><span class="pill pill-doc">NotebookLM</span><span class="pill pill-auto">Make / Zapier</span></div></td>
          <td class="col-caso">Redactar avisos y automatizar onboarding de nuevos ingresos</td>
          <td><span class="pri pri-med">Media</span></td>
        </tr>
        <tr>
          <td><strong>Atenci&#243;n al cliente</strong><br/><span class="rubro-sub">Coordinadores, supervisores de CS</span></td>
          <td><div class="pills"><span class="pill pill-gen">ChatGPT / Claude</span><span class="pill pill-auto">Make / Zapier</span></div></td>
          <td class="col-caso">Responder consultas frecuentes y automatizar seguimiento de casos</td>
          <td><span class="pri pri-high">Alta</span></td>
        </tr>
        <tr>
          <td><strong>Educaci&#243;n y capacitaci&#243;n</strong><br/><span class="rubro-sub">Docentes, coordinadores, dise&#241;adores instruccionales</span></td>
          <td><div class="pills"><span class="pill pill-gen">ChatGPT / Claude</span><span class="pill pill-pres">Gamma</span><span class="pill pill-doc">NotebookLM</span></div></td>
          <td class="col-caso">Crear materiales de clase, actividades y r&#250;bricas desde un tema</td>
          <td><span class="pri pri-med">Media</span></td>
        </tr>
        <tr>
          <td><strong>Salud y cl&#237;nicas</strong><br/><span class="rubro-sub">Administradores, coordinadores (no cl&#237;nico)</span></td>
          <td><div class="pills"><span class="pill pill-auto">Make / Zapier</span><span class="pill pill-gen">ChatGPT / Claude</span><span class="pill pill-doc">NotebookLM</span></div></td>
          <td class="col-caso">Automatizar turnos y resumir protocolos para el equipo</td>
          <td><span class="pri pri-med">Media</span></td>
        </tr>
        <tr>
          <td><strong>Arquitectura, ingenier&#237;a y construcci&#243;n</strong><br/><span class="rubro-sub">Directores de obra, project owners</span></td>
          <td><div class="pills"><span class="pill pill-gen">ChatGPT / Claude</span><span class="pill pill-pres">Gamma</span><span class="pill pill-auto">Make / Zapier</span></div></td>
          <td class="col-caso">Preparar presentaciones de avance y gestionar comunicaciones de proyecto</td>
          <td><span class="pri pri-med">Media</span></td>
        </tr>
        <tr>
          <td><strong>Emprendedores y PyMEs</strong><br/><span class="rubro-sub">Due&#241;os de negocio, founders</span></td>
          <td><div class="pills"><span class="pill pill-gen">ChatGPT / Claude</span><span class="pill pill-pres">Gamma</span><span class="pill pill-auto">Make / Zapier</span><span class="pill pill-anal">Perplexity</span></div></td>
          <td class="col-caso">Hacer el trabajo de 3 perfiles sin equipo grande</td>
          <td><span class="pri pri-vhigh">Muy alta</span></td>
        </tr>
      </tbody>
    </table>
  </div>
</div>

<style>
  .mapa-wrap { margin: 2rem 0; }

  .mapa-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 1rem;
  }

  .leg-item {
    font-size: 0.78rem;
    font-weight: 500;
    padding: 3px 10px;
    border-radius: 99px;
    border: 1px solid;
  }

  .leg-gen  { background: #E6F1FB; color: #0C447C; border-color: #85B7EB; }
  .leg-auto { background: #EAF3DE; color: #3B6D11; border-color: #97C459; }
  .leg-pres { background: #EEEDFE; color: #3C3489; border-color: #AFA9EC; }
  .leg-anal { background: #FAEEDA; color: #633806; border-color: #EF9F27; }
  .leg-doc  { background: #E1F5EE; color: #085041; border-color: #5DCAA5; }

  .table-wrap {
    width: 100%;
    border-radius: 10px;
    border: 1px solid var(--color-border);
    overflow: hidden;
    overflow-x: auto;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.82rem;
    min-width: 600px;
  }

  thead tr { background: var(--color-text); }

  thead th {
    text-align: left;
    padding: 10px 14px;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.75);
    white-space: nowrap;
  }

  tbody tr {
    border-bottom: 1px solid var(--color-border);
    transition: background 0.15s;
  }

  tbody tr:last-child { border-bottom: none; }
  tbody tr:nth-child(even) { background: var(--color-surface); }
  tbody tr:hover { background: #EAF3EC; }

  td {
    padding: 12px 14px;
    vertical-align: top;
    color: var(--color-text);
    line-height: 1.5;
  }

  .rubro-sub {
    font-size: 0.75rem;
    color: var(--color-muted);
    display: block;
    margin-top: 2px;
  }

  .col-caso {
    color: var(--color-muted);
    max-width: 200px;
  }

  .pills { display: flex; flex-wrap: wrap; gap: 4px; }

  .pill {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 500;
    padding: 2px 8px;
    border-radius: 99px;
    border: 1px solid;
    white-space: nowrap;
  }

  .pill-gen  { background: #E6F1FB; color: #0C447C; border-color: #85B7EB; }
  .pill-auto { background: #EAF3DE; color: #3B6D11; border-color: #97C459; }
  .pill-pres { background: #EEEDFE; color: #3C3489; border-color: #AFA9EC; }
  .pill-anal { background: #FAEEDA; color: #633806; border-color: #EF9F27; }
  .pill-doc  { background: #E1F5EE; color: #085041; border-color: #5DCAA5; }

  .pri {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 99px;
    border: 1px solid;
    white-space: nowrap;
  }

  .pri-high  { background: #EAF3DE; color: #3B6D11; border-color: #97C459; }
  .pri-vhigh { background: #FAEEDA; color: #633806; border-color: #EF9F27; }
  .pri-med   { background: #F1EFE8; color: #444441; border-color: #B4B2A9; }
  .pri-medh  { background: #E6F1FB; color: #0C447C; border-color: #85B7EB; }

  @media (max-width: 640px) {
    .col-caso { display: none; }
  }
</style>