---
---
<header class="site-header">
  <div class="container--wide header-inner">
    <a href="/" class="site-logo" aria-label="Valeria Yashan — Inicio">
      <img src="/images/horizontal-claro.svg" alt="Valeria Yashan PMP® · Project Management · IA Aplicada" width="200" height="44" />
    </a>
    <nav aria-label="Navegación principal">
      <ul class="nav-list">
        <li><a href="/" class="nav-link">Inicio</a></li>
        <li><a href="/sobre-mi" class="nav-link">Sobre mí</a></li>
        <li><a href="/servicios" class="nav-link">Servicios</a></li>
        <li><a href="/libro" class="nav-link">Libros</a></li>
        <li><a href="/blog" class="nav-link">Blog</a></li>
        <li><a href="/recursos" class="nav-link">Recursos</a></li>
        <li><a href="/herramientas" class="nav-link">Herramientas</a></li>
        <li><a href="/capacitacion" class="nav-link">Capacitación</a></li>
        <li><a href="/contacto" class="nav-link">Contacto</a></li>
      </ul>
    </nav>
    <a href="https://calendly.com/valeriayashan/30min" target="_blank" rel="noopener" class="btn-calendly">Agendá una consulta</a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    padding: 0.75rem 0;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .site-logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }

  .site-logo img {
    height: 44px;
    width: auto;
    display: block;
  }

  .nav-list {
    display: flex;
    list-style: none;
    gap: 1.5rem;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .nav-link:hover {
    color: var(--color-accent);
  }

  .btn-calendly {
    display: inline-flex;
    align-items: center;
    background: var(--color-accent);
    color: #ffffff;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 0.875rem;
    padding: 0.55rem 1.1rem;
    border-radius: 6px;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    min-height: 40px;
    transition: opacity 0.2s;
  }

  .btn-calendly:hover {
    opacity: 0.88;
  }

  @media (max-width: 700px) {
    .header-inner {
      flex-wrap: wrap;
      gap: 0.75rem;
    }

    .site-logo img {
      height: 36px;
    }

    .nav-list {
      gap: 1rem;
      flex-wrap: wrap;
      order: 3;
      width: 100%;
    }

    .nav-link {
      font-size: 0.85rem;
    }

    .btn-calendly {
      font-size: 0.8rem;
      padding: 0.45rem 0.9rem;
    }
  }
</style>