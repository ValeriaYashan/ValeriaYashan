    <li><a href="/sobre-mi" class="nav-mobile-link">Sobre mí</a></li>
    <li>
      <a href="/servicios" class="nav-mobile-link">Servicios</a>
      <ul class="nav-mobile-sub">
        <li><a href="/servicios/consultoria-pm" class="nav-mobile-sublink">Consultoría en Gestión de Proyectos</a></li>
        <li><a href="/servicios/direccion-proyectos" class="nav-mobile-sublink">Dirección de Proyectos Externa</a></li>
        <li><a href="/servicios/capacitacion-pm" class="nav-mobile-sublink">Capacitación en Project Management</a></li>
        <li><a href="/servicios/consultoria-ia" class="nav-mobile-sublink">Consultoría en IA Aplicada</a></li>
